------------------------------------------------------------------------
-- WASD PAD GUI  (sürüklenebilir)
------------------------------------------------------------------------
local padGui

local function CreateWASDPad()
	if padGui then padGui:Destroy(); padGui=nil end

	padGui = Instance.new("ScreenGui")
	padGui.Name="FCPad"; padGui.ResetOnSpawn=false
	padGui.IgnoreGuiInset=true; padGui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
	padGui.Parent=CoreGui

	-- Ana çerçeve (sürüklenebilir)
	local BTN = 54    -- buton boyutu
	local GAP = 4     -- boşluk
	local PAD_W = BTN*3 + GAP*4
	local PAD_H = BTN*4 + GAP*5 + 20  -- +20 başlık

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0, PAD_W, 0, PAD_H)
	-- Başlangıç: sol alt
	frame.Position = UDim2.new(0, 12, 1, -(PAD_H+12))
	frame.BackgroundColor3 = C.padBg
	frame.BackgroundTransparency = 0.1
	frame.BorderSizePixel = 0
	frame.Parent = padGui
	UICornerR(12, frame)
	UIStrokeC(C.border, 1, frame)

	-- Başlık + sürükleme tutacağı
	local header = Instance.new("TextButton")
	header.Size = UDim2.new(1,0,0,20)
	header.BackgroundColor3 = C.bgDark
	header.BackgroundTransparency = 0.1
	header.BorderSizePixel = 0
	header.Text = "✥ MOVE"
	header.Font = Enum.Font.Code
	header.TextSize = 11
	header.TextColor3 = C.textDim
	header.Parent = frame
	UICornerR(10, header)
	-- Alt köşeleri düz yap
	local hFix = Instance.new("Frame")
	hFix.Size=UDim2.new(1,0,0,6); hFix.Position=UDim2.new(0,0,1,-6)
	hFix.BackgroundColor3=C.bgDark; hFix.BorderSizePixel=0; hFix.Parent=header

	-- Sürükleme mantığı
	local dragging, dragStart, frameStart = false, nil, nil
	header.InputBegan:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1
		or inp.UserInputType==Enum.UserInputType.Touch then
			dragging   = true
			dragStart  = Vector2.new(inp.Position.X, inp.Position.Y)
			frameStart = frame.Position
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if not dragging then return end
		if inp.UserInputType==Enum.UserInputType.MouseMovement
		or inp.UserInputType==Enum.UserInputType.Touch then
			local d = Vector2.new(inp.Position.X, inp.Position.Y) - dragStart
			frame.Position = UDim2.new(
				frameStart.X.Scale, frameStart.X.Offset + d.X,
				frameStart.Y.Scale, frameStart.Y.Offset + d.Y
			)
		end
	end)
	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1
		or inp.UserInputType==Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	-- Buton fabrikası
	-- col/row: grid pozisyonu (0-tabanlı), padKey: Pad tablosundaki key
	local function MakeKey(label, col, row, padKey, extraW)
		extraW = extraW or 0
		local x = GAP + col*(BTN+GAP)
		local y = 20 + GAP + row*(BTN+GAP)
		local w = BTN + extraW

		local btn = Instance.new("TextButton")
		btn.Size = UDim2.new(0, w, 0, BTN)
		btn.Position = UDim2.new(0, x, 0, y)
		btn.BackgroundColor3 = C.padBtn
		btn.BackgroundTransparency = 0.15
		btn.BorderSizePixel = 0
		btn.Text = label
		btn.Font = Enum.Font.Code
		btn.TextSize = 20
		btn.TextColor3 = C.text
		btn.AutoButtonColor = false
		btn.Parent = frame
		UICornerR(8, btn)
		UIStrokeC(Color3.fromRGB(60, 82, 120), 1, btn)

		local function Press()
			Pad[padKey] = 1
			btn.BackgroundColor3 = C.padBtnAct
		end
		local function Release()
			Pad[padKey] = 0
			btn.BackgroundColor3 = C.padBtn
		end

		btn.MouseButton1Down:Connect(Press)
		btn.MouseButton1Up:Connect(Release)
		btn.MouseLeave:Connect(Release)
		-- Touch desteği
		btn.TouchLongPress:Connect(function() end)
		btn.InputBegan:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.Touch then Press() end
		end)
		btn.InputEnded:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.Touch then Release() end
		end)
		return btn
	end

	--[[
		Düzen:
		   [  ↑ W  ]
		[← A][   ][D →]
		   [  ↓ S  ]
		   ─────────
		[↑ E]      [Q ↓]   ← yukarı/aşağı
		[ ↺ ]      [ ↻ ]   ← roll
		─────────────────
		[FOV+]    [FOV-]
	]]

	-- Satır 0: W (ortada)
	MakeKey("▲", 1, 0, "W")
	-- Satır 1: A, boşluk, D
	MakeKey("◀", 0, 1, "A")
	MakeKey("▶", 2, 1, "D")
	-- Satır 2: S (ortada)
	MakeKey("▼", 1, 2, "S")
	-- Satır 3: E (yukarı çık) ve Q (aşağı in)
	MakeKey("E↑", 0, 3, "Up")
	MakeKey("Q↓", 2, 3, "Down")

	-- FOV ve Roll: çerçevenin dışında değil, 4. satırda
	-- PAD_H'i yeniden hesapla
	-- (zaten 4 satır + başlık ile PAD_H doğru)

	return padGui
end

local function DestroyWASDPad()
	if padGui then padGui:Destroy(); padGui=nil end
	-- Pad durumunu sıfırla
	for k in pairs(Pad) do Pad[k] = 0 end
end

------------------------------------------------------------------------
-- CONFIG PANELİ
------------------------------------------------------------------------
local confGui  = nil
local confOpen = false

local function MakeSlider(parent, configKey, minVal, maxVal, yPos, labelText, fmt)
	fmt = fmt or "%.2f"
	local ROW = 30

	local row = Instance.new("Frame")
	row.Size=UDim2.new(1,0,0,ROW); row.Position=UDim2.new(0,0,0,yPos)
	row.BackgroundTransparency=1; row.Parent=parent

	local lbl=Lbl(labelText,11,C.textDim,row)
	lbl.Size=UDim2.new(0,138,1,0)

	local valLbl=Lbl(string.format(fmt,Config[configKey]),11,C.text,row,Enum.TextXAlignment.Right)
	valLbl.Size=UDim2.new(0,46,1,0); valLbl.Position=UDim2.new(1,-46,0,0)

	local track=Instance.new("Frame")
	track.Size=UDim2.new(1,-192,0,6); track.Position=UDim2.new(0,142,0.5,-3)
	track.BackgroundColor3=C.sliderBg; track.BorderSizePixel=0; track.Parent=row
	UICornerR(3,track)

	local fill=Instance.new("Frame")
	fill.BackgroundColor3=C.sliderFill; fill.BorderSizePixel=0
	fill.Size=UDim2.new(0,0,1,0); fill.Parent=track; UICornerR(3,fill)

	local knob=Instance.new("Frame")
	knob.Size=UDim2.new(0,14,0,14); knob.AnchorPoint=Vector2.new(0.5,0.5)
	knob.BackgroundColor3=Color3.fromRGB(240,245,255)
	knob.BorderSizePixel=0; knob.Parent=track; UICornerR(7,knob)

	local function SetVal(t)
		t = clamp(t,0,1)
		Config[configKey] = math.floor((minVal + t*(maxVal-minVal))*100+0.5)/100
		fill.Size = UDim2.new(t,0,1,0)
		knob.Position = UDim2.new(t,0,0.5,0)
		valLbl.Text = string.format(fmt, Config[configKey])
	end
	SetVal((Config[configKey]-minVal)/(maxVal-minVal))

	local dragging = false
	local function ApplyX(absX)
		local ap=track.AbsolutePosition; local as=track.AbsoluteSize
		if as.X==0 then return end
		SetVal((absX-ap.X)/as.X)
	end
	track.InputBegan:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1
		or inp.UserInputType==Enum.UserInputType.Touch then
			dragging=true; ApplyX(inp.Position.X)
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if not dragging then return end
		if inp.UserInputType==Enum.UserInputType.MouseMovement
		or inp.UserInputType==Enum.UserInputType.Touch then
			ApplyX(inp.Position.X)
		end
	end)
	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1
		or inp.UserInputType==Enum.UserInputType.Touch then
			dragging=false
		end
	end)
end

