-- Desktop Shift+P toggle
if not IsMobile then
	ContextActionService:BindActionAtPriority("FCToggle", function(_, state, input)
		if state==Enum.UserInputState.Begin and input.KeyCode==Enum.KeyCode.P then
			if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
				ToggleFreecam()
			end
		end
		return Enum.ContextActionResult.Pass
	end, false, Enum.ContextActionPriority.Low.Value, Enum.KeyCode.P)
end

script:SetAttribute("FreecamEnabled", false)
script:GetAttributeChangedSignal("FreecamEnabled"):Connect(function()
	local v=script:GetAttribute("FreecamEnabled")
	if typeof(v)~="boolean" then script:SetAttribute("FreecamEnabled",freecamEnabled); return end
	if v~=freecamEnabled then
		if v then StartFreecam() else StopFreecam() end
		freecamEnabled=v
	end
end)

if not IsMobile then
	StarterGui:SetCore("SendNotification",{
		Title="Freecam v4",
		Text="Shift+P toggle  ·  ⚙ Config  ·  WASD pad aktif"
	})
end
