local function CreateConfigPanel()
	if confGui then confGui:Destroy(); confGui=nil end

	local W,H = 460,310
	confGui=Instance.new("ScreenGui")
	confGui.Name="FCConfig"; confGui.ResetOnSpawn=false
	confGui.IgnoreGuiInset=true; confGui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
	confGui.Parent=CoreGui

	local win=Instance.new("Frame")
	win.Size=UDim2.new(0,W,0,H); win.Position=UDim2.new(0.5,-W/2,0.5,-H/2)
	win.BackgroundColor3=C.bg; win.BorderSizePixel=0; win.Parent=confGui
	UICornerR(5,win); UIStrokeC(C.border,1,win)

	-- Başlık barı
	local titleBar=Instance.new("Frame")
	titleBar.Size=UDim2.new(1,0,0,28); titleBar.BackgroundColor3=C.header
	titleBar.BorderSizePixel=0; titleBar.Parent=win; UICornerR(5,titleBar)
	local fix=Instance.new("Frame")
	fix.Size=UDim2.new(1,0,0,6); fix.Position=UDim2.new(0,0,1,-6)
	fix.BackgroundColor3=C.header; fix.BorderSizePixel=0; fix.Parent=titleBar

	local tLbl=Lbl("Freecam  ·  Configuration",13,C.text,titleBar)
	tLbl.Size=UDim2.new(1,-50,1,0); tLbl.Position=UDim2.new(0,10,0,0)

	-- Kapat butonu
	local closeDot=Instance.new("Frame")
	closeDot.Size=UDim2.new(0,12,0,12); closeDot.Position=UDim2.new(1,-18,0.5,-6)
	closeDot.BackgroundColor3=C.red; closeDot.BorderSizePixel=0; closeDot.Parent=titleBar
	UICornerR(6,closeDot)
	local closeHit=Instance.new("TextButton")
	closeHit.Size=UDim2.fromScale(1,1); closeHit.BackgroundTransparency=1
	closeHit.Text=""; closeHit.Parent=closeDot
	closeHit.MouseButton1Click:Connect(function()
		confOpen=false; confGui:Destroy(); confGui=nil
	end)

	-- Pencere sürükleme
	local ds,dws
	titleBar.InputBegan:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1
		or inp.UserInputType==Enum.UserInputType.Touch then
			ds=Vector2.new(inp.Position.X,inp.Position.Y); dws=win.Position
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if not ds then return end
		if inp.UserInputType==Enum.UserInputType.MouseMovement
		or inp.UserInputType==Enum.UserInputType.Touch then
			local d=Vector2.new(inp.Position.X,inp.Position.Y)-ds
			win.Position=UDim2.new(dws.X.Scale,dws.X.Offset+d.X,dws.Y.Scale,dws.Y.Offset+d.Y)
		end
	end)
	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1
		or inp.UserInputType==Enum.UserInputType.Touch then ds=nil end
	end)

	-- Sekme barı
	local TABY=28
	local tabBar=Instance.new("Frame")
	tabBar.Size=UDim2.new(1,0,0,26); tabBar.Position=UDim2.new(0,0,0,TABY)
	tabBar.BackgroundColor3=C.bgDark; tabBar.BorderSizePixel=0; tabBar.Parent=win

	local content=Instance.new("Frame")
	content.Size=UDim2.new(1,-16,1,-(TABY+26+42)); content.Position=UDim2.new(0,8,0,TABY+26+8)
	content.BackgroundTransparency=1; content.ClipsDescendants=true; content.Parent=win

	local curPage=nil; local tabBtns={}

	local function SwitchTab(idx)
		if curPage then curPage:Destroy() end
		for i,btn in ipairs(tabBtns) do
			btn.BackgroundColor3=i==idx and C.tabActive or C.tabInact
			btn.TextColor3=i==idx and Color3.fromRGB(255,255,255) or C.textDim
		end
		curPage=Instance.new("Frame")
		curPage.Size=UDim2.fromScale(1,1); curPage.BackgroundTransparency=1
		curPage.Parent=content
		TABS[idx].build(curPage)
	end

	local tabW=math.floor(W/#TABS)
	for i,tab in ipairs(TABS) do
		local btn=Instance.new("TextButton")
		btn.Size=UDim2.new(0,tabW,1,0); btn.Position=UDim2.new(0,(i-1)*tabW,0,0)
		btn.BackgroundColor3=C.tabInact; btn.BorderSizePixel=0
		btn.Text=tab.name; btn.Font=Enum.Font.Code; btn.TextSize=12
		btn.TextColor3=C.textDim; btn.Parent=tabBar
		tabBtns[i]=btn
		btn.MouseButton1Click:Connect(function() SwitchTab(i) end)
	end
	SwitchTab(1)

	-- Alt bar
	local bot=Instance.new("Frame")
	bot.Size=UDim2.new(1,0,0,34); bot.Position=UDim2.new(0,0,1,-34)
	bot.BackgroundColor3=C.bgDark; bot.BorderSizePixel=0; bot.Parent=win

	local togBtn=Instance.new("TextButton")
	togBtn.Size=UDim2.new(0,148,0,24); togBtn.Position=UDim2.new(0,8,0.5,-12)
	togBtn.BackgroundColor3=freecamEnabled and C.red or C.green
	togBtn.BorderSizePixel=0; togBtn.Parent=bot
	togBtn.Font=Enum.Font.Code; togBtn.TextSize=12
	togBtn.TextColor3=Color3.fromRGB(255,255,255)
	togBtn.Text=freecamEnabled and "■  Stop Freecam" or "▶  Start Freecam"
	UICornerR(5,togBtn)
	togBtn.MouseButton1Click:Connect(function()
		ToggleFreecam()
		togBtn.BackgroundColor3=freecamEnabled and C.red or C.green
		togBtn.Text=freecamEnabled and "■  Stop Freecam" or "▶  Start Freecam"
	end)

	local statusLbl=Lbl("",10,C.textDim,bot)
	statusLbl.Size=UDim2.new(1,-164,1,0); statusLbl.Position=UDim2.new(0,158,0,0)
	RunService.Heartbeat:Connect(function()
		if not confGui or not confGui.Parent then return end
		statusLbl.Text=string.format("FOV:%d  Spd:%.1f  Sens:%.1f  %s%s",
			math.floor(cameraFov), Config.MoveSpeed, Config.LookSens,
			freecamEnabled and "● ACTIVE" or "○ Standby",
			Config.CharLock and "  🔒" or "")
	end)
end

local function ToggleConfig()
	confOpen=not confOpen
	if confOpen then CreateConfigPanel()
	elseif confGui then confGui:Destroy(); confGui=nil end
end

