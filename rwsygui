        if not staticJoy.lockedPos then
            staticJoy.lockedPos = thumbFrame.Position
        end
        thumbFrame.Position = staticJoy.lockedPos
        staticJoy.conn = thumbFrame:GetPropertyChangedSignal("Position"):Connect(function()
            if staticJoy.enabled and staticJoy.lockedPos then
                thumbFrame.Position = staticJoy.lockedPos
            end
        end)
    end)
    if not ok then warn("[Raiwesy] Sabit Joystick: TouchGui bulunamadı — "..tostring(err)) end
end

