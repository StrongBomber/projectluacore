    for _, n in ipairs({"RaiLockBP", "RaiLockBG"}) do
        local o = hrp:FindFirstChild(n); if o then o:Destroy() end
    end
    charLock.frozenPos = hrp.CFrame
    local bp = Instance.new("BodyPosition")
    bp.Name="RaiLockBP"; bp.MaxForce=Vector3.new(math.huge,math.huge,math.huge)
    bp.P=1e6; bp.D=1e4; bp.Position=hrp.Position; bp.Parent=hrp
    local bg = Instance.new("BodyGyro")
    bg.Name="RaiLockBG"; bg.MaxTorque=Vector3.new(math.huge,math.huge,math.huge)
    bg.P=1e6; bg.D=1e3; bg.CFrame=hrp.CFrame; bg.Parent=hrp
    local hum = getHum()
    if hum then hum.WalkSpeed=0; hum.JumpPower=0; hum.AutoRotate=false end
    if charLock.stepped then charLock.stepped:Disconnect() end
    charLock.stepped = RunService.Stepped:Connect(function()
        if not charLock.enabled then return end
        local h=getHRP()
        local bp2=h and h:FindFirstChild("RaiLockBP")
        local bg2=h and h:FindFirstChild("RaiLockBG")
        if bp2 then bp2.Position=charLock.frozenPos.Position end
        if bg2 then bg2.CFrame=charLock.frozenPos end
        local hm=getHum()
        if hm then hm.WalkSpeed=0; hm.JumpPower=0 end
    end)
end

local function charLockRelease()
    if charLock.stepped then charLock.stepped:Disconnect(); charLock.stepped=nil end
    local hrp=getHRP()
    if hrp then
        for _,n in ipairs({"RaiLockBP","RaiLockBG"}) do
            local o=hrp:FindFirstChild(n); if o then o:Destroy() end
        end
    end
    local hum=getHum()
    if hum then
        hum.WalkSpeed=S.speed and S.speedVal or 16
        hum.JumpPower=S.infJump and S.jumpVal or 50
        hum.AutoRotate=true
    end
    charLock.frozenPos=nil
end

