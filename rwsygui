local espTick=0; local infoTick=0
RunService.Heartbeat:Connect(function(dt)
    local now=os.clock()

    infoTick=infoTick+dt
    if infoTick>=1 then infoTick=0; if _G.RaiwesyRefreshInfo then _G.RaiwesyRefreshInfo() end end

    if S.speed then local hum=getHum(); if hum then hum.WalkSpeed=S.speedVal end end
    if S.infJump then local hum=getHum(); if hum then hum.JumpPower=S.jumpVal end end
    if S.godMode then local hum=getHum(); if hum and hum.Health<hum.MaxHealth then hum.Health=hum.MaxHealth end end
    if S.fly and not S.flyConn then startFly() end
    if S.freeCam and not S.fcConn then startFreeCam() end
    if S.antiAFK and now-S.lastAFK>60 then S.lastAFK=now; local hum=getHum(); if hum then hum.Jump=true end end

    espTick=espTick+dt
    if espTick>=0.5 then espTick=0; updateESP() end

    -- CB ESP
    if cb.esp_active then cbUpdateESP() end

    -- CB FOV dairesi
    if cb.aim_fov_visible and cb.aim_enabled then
        cb_fov_circle.Visible=true
        cb_fov_circle.Position=Vector2.new(camera.ViewportSize.X/2,camera.ViewportSize.Y/2)
        cb_fov_circle.Radius=cb.aim_fov; cb_fov_circle.Color=cb.aim_fov_color
    else cb_fov_circle.Visible=false end

    -- CB Aimbot (otomatik)
    if cb.aim_enabled then local target=cbGetClosest(); if target then cbAimAt(target) end end

    -- ══════════════════════════════════════
    --  LEGİT AİMBOT — bölge değiştirici timer
    -- ══════════════════════════════════════
    if cb.legit_aim_enabled then
        cb.legit_aim_timer = cb.legit_aim_timer + dt
        if cb.legit_aim_timer >= cb.legit_aim_interval then
            cb.legit_aim_timer = 0
            cbPickRandomPart()
        end
    end
end)

