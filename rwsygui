--  SİLENT AİM — mt.__namecall HOOK
-- ══════════════════════════════════════
task.spawn(function()
    local waited = 0
    while not getrawmetatable and waited < 5 do
        task.wait(1); waited = waited + 1
    end
    if not getrawmetatable then
        warn("[Raiwesy] Silent Aim: getrawmetatable bulunamadı — executor desteklemiyor olabilir.")
        if SA.active_label then
            SA.active_label.Text = "❌  Silent Aim: Executor desteklemiyor"
            SA.active_label.TextColor3 = C.red
        end
        return
    end

    local ok, err = pcall(function()
        local mt = getrawmetatable(game)
        local oldNamecall = mt.__namecall
        setreadonly(mt, false)
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if method == "FindPartOnRayWithIgnoreList" and SA.enabled and SA._target then
                if math.random(1, 100) <= SA.hitchance then
                    local tgt = SA._target
                    if tgt and tgt.Parent then
                        local origin = camera.CFrame.Position
                        local dir    = (tgt.Position - origin)
                        local newRay = Ray.new(origin, dir.Unit * math.min(dir.Magnitude, 999))
                        local args   = {...}
                        args[1]      = newRay
                        if SA.active_label then
                            local pname = tgt.Parent and tgt.Parent.Name or "?"
                            SA.active_label.Text = string.format(
                                "🎯  %s → %s  (%d%%)",
                                SA.target_part, pname, SA.hitchance
                            )
                            SA.active_label.TextColor3 = C.green
                        end
                        return oldNamecall(self, table.unpack(args))
                    end
                end
            end
            return oldNamecall(self, ...)
        end)
        setreadonly(mt, true)
    end)

    if not ok then
        warn("[Raiwesy] Silent Aim hook hatası: " .. tostring(err))
        if SA.active_label then
            SA.active_label.Text = "❌  Hook hatası: " .. tostring(err):sub(1, 40)
            SA.active_label.TextColor3 = C.red
        end
    end
end)

