local function makePopup(btnParent, btnOrder, btnText, items, stateTable, onToggle)
    local popupFrame = Instance.new("Frame")
    popupFrame.BackgroundColor3 = C.input_bg
    popupFrame.BorderSizePixel  = 0
    popupFrame.ZIndex           = 112
    popupFrame.Visible          = false
    popupFrame.ClipsDescendants = false
    popupFrame.Parent           = SG
    corner(popupFrame, 6); stroke(popupFrame, 1.5, C.accent)
    local ul = Instance.new("UIListLayout")
    ul.SortOrder = Enum.SortOrder.LayoutOrder; ul.Parent = popupFrame

    for i, item in ipairs(items) do
        local isOn = stateTable[item] ~= false
        local rb = frame(popupFrame, UDim2.new(1,0,0,ROW_H), UDim2.new(0,0,0,0), C.row_a)
        rb.LayoutOrder = i
        lbl(rb, item, UDim2.new(1,-46,1,0), UDim2.new(0,10,0,0), C.txt_lbl, 13)
        local cb2 = frame(rb, UDim2.new(0,24,0,24), UDim2.new(1,-34,0.5,-12),
            isOn and C.chk_on or C.chk_off)
        corner(cb2, 4); stroke(cb2, 1, C.border)
        local ct = lbl(cb2, isOn and "✓" or "",
            UDim2.new(1,0,1,0), UDim2.new(0,0,0,0),
            Color3.new(1,1,1), 14, Enum.TextXAlignment.Center)
        local ov = Instance.new("TextButton")
        ov.Size=UDim2.new(1,0,1,0); ov.BackgroundTransparency=1
        ov.Text=""; ov.ZIndex=113; ov.Parent=rb
        ov.MouseButton1Click:Connect(function()
            isOn = not isOn
            stateTable[item] = isOn
            cb2.BackgroundColor3 = isOn and C.chk_on or C.chk_off
            ct.Text = isOn and "✓" or ""
            if onToggle then onToggle(item, isOn) end
        end)
    end

    popupFrame.Size = UDim2.new(0, 220, 0, ROW_H * #items + 2)

    local openBtn = mkbtn(btnParent, btnText .. "  ▼",
        UDim2.new(1,0,0,44), UDim2.new(0,0,0,0), C.btn_dark, C.txt, 13)
    openBtn.LayoutOrder = btnOrder
    stroke(openBtn, 1, C.border)

    local isOpen = false
    local function closeP()
        isOpen = false; popupFrame.Visible = false
        openBtn.Text = btnText .. "  ▼"
    end
    local function openP()
        isOpen = true
        local ap = openBtn.AbsolutePosition; local as = openBtn.AbsoluteSize
        local vps = camera.ViewportSize
        local px = ap.X; local py = ap.Y + as.Y + 2
        local ph = ROW_H * #items + 2
        if py + ph > vps.Y - 8 then py = ap.Y - ph - 2 end
        if px + 220 > vps.X - 4 then px = vps.X - 224 end
        popupFrame.Position = UDim2.new(0, px, 0, py)
        popupFrame.Visible  = true
        openBtn.Text = btnText .. "  ▲"
    end

    openBtn.MouseButton1Click:Connect(function()
        if isOpen then closeP() else openP() end
    end)
    UserInputService.InputBegan:Connect(function(inp)
        if not isOpen then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1
           and inp.UserInputType ~= Enum.UserInputType.Touch then return end
        task.wait()
        local mp = inp.Position
        local pp = popupFrame.AbsolutePosition; local ps = popupFrame.AbsoluteSize
        local bp = openBtn.AbsolutePosition;    local bs = openBtn.AbsoluteSize
        local inP = mp.X>=pp.X and mp.X<=pp.X+ps.X and mp.Y>=pp.Y and mp.Y<=pp.Y+ps.Y
        local inB = mp.X>=bp.X and mp.X<=bp.X+bs.X and mp.Y>=bp.Y and mp.Y<=bp.Y+bs.Y
        if not inP and not inB then closeP() end
    end)

    return openBtn, closeP
end

