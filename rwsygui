local function updateESP()
    if not S.espEnabled then return end
    for name,d in pairs(S.espBoxes) do
        local plr=Players:FindFirstChild(name)
        if not plr or not plr.Character then
            if d.bill and d.bill.Parent then d.bill:Destroy() end
            S.espBoxes[name]=nil
        end
    end
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=player and plr.Character then
            local hrp=plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local d=S.espBoxes[plr.Name]
                if not d then
                    local bill=Instance.new("BillboardGui")
                    bill.Size=UDim2.new(0,120,0,50); bill.StudsOffset=Vector3.new(0,3.5,0)
                    bill.AlwaysOnTop=true; bill.Parent=hrp
                    local nL=Instance.new("TextLabel")
                    nL.Size=UDim2.new(1,0,0.5,0); nL.BackgroundTransparency=1
                    nL.Font=Enum.Font.GothamBold; nL.TextSize=15
                    nL.TextStrokeTransparency=0; nL.TextStrokeColor3=Color3.new(0,0,0)
                    nL.TextColor3=Color3.fromRGB(255,80,80); nL.Parent=bill
                    local dL=Instance.new("TextLabel")
                    dL.Size=UDim2.new(1,0,0.5,0); dL.Position=UDim2.new(0,0,0.5,0)
                    dL.BackgroundTransparency=1; dL.Font=Enum.Font.Code; dL.TextSize=12
                    dL.TextStrokeTransparency=0; dL.TextStrokeColor3=Color3.new(0,0,0)
                    dL.TextColor3=Color3.fromRGB(255,220,50); dL.Parent=bill
                    local hi=Instance.new("SelectionBox")
                    hi.LineThickness=0.06; hi.Color3=Color3.fromRGB(255,60,60)
                    hi.SurfaceTransparency=0.75; hi.SurfaceColor3=Color3.fromRGB(255,60,60)
                    hi.Adornee=plr.Character; hi.Parent=bill
                    S.espBoxes[plr.Name]={bill=bill,nameL=nL,distL=dL,hi=hi}; d=S.espBoxes[plr.Name]
                end
                local myHRP=getHRP()
                local dist=myHRP and math.floor((hrp.Position-myHRP.Position).Magnitude) or 0
                d.nameL.Text=plr.DisplayName; d.distL.Text=tostring(dist).."m"; d.bill.Parent=hrp
            end
        end
    end
end

