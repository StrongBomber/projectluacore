        checked and C.chk_on or C.chk_off)
    corner(box, 5); stroke(box, 1, C.border)
    local chkL = lbl(box, checked and "✓" or "",
        UDim2.new(1,0,1,0), UDim2.new(0,0,0,0),
        Color3.fromRGB(255,255,255), 14, Enum.TextXAlignment.Center)
    local ov = Instance.new("TextButton")
