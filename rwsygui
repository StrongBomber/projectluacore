    if S.speed   then local h=getHum(); if h then h.WalkSpeed=S.speedVal end end
    if S.infJump then local h=getHum(); if h then h.JumpPower=S.jumpVal  end end
    if S.godMode then local h=getHum(); if h then h.MaxHealth=math.huge; h.Health=math.huge end end
    if S.fly     then S.flyConn=nil; startFly() end
    if cb.cbfly_enabled then cbStartFly() end
    task.wait(1); cbRefreshAll()
end)

-- CB Oyuncu olayları
Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function() task.wait(1); if p~=player then cbBuild(p) end end)
end)
Players.PlayerRemoving:Connect(function(p) cbClean(p) end)

-- CB Periyodik yenileme
task.spawn(function()
    task.wait(1); cbRefreshAll()
    while task.wait(30) do if cb.esp_active then cbRefreshAll() end end
end)

