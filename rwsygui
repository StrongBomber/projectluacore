local function cbStartFly()
    local hrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _,n in ipairs({"RaiFlyBG","RaiFlyBV","CB_FlyBG","CB_FlyBV"}) do
        local o=hrp:FindFirstChild(n); if o then o:Destroy() end
    end
    local bg=Instance.new("BodyGyro")
    bg.Name="CB_FlyBG"; bg.MaxTorque=Vector3.new(9e9,9e9,9e9)
    bg.CFrame=hrp.CFrame; bg.D=50; bg.P=1e5; bg.Parent=hrp
    local bv=Instance.new("BodyVelocity")
    bv.Name="CB_FlyBV"; bv.Velocity=Vector3.zero; bv.MaxForce=Vector3.new(9e9,9e9,9e9); bv.Parent=hrp
    if cbFlyConn then cbFlyConn:Disconnect() end
    cbFlyConn=RunService.Heartbeat:Connect(function()
        if not cb.cbfly_enabled then
            cbFlyConn:Disconnect(); cbFlyConn=nil
            for _,n in ipairs({"CB_FlyBG","CB_FlyBV"}) do
                local o=hrp:FindFirstChild(n); if o then o:Destroy() end
            end
            return
        end
        local dir=Vector3.zero; local cf=camera.CFrame
        if cbFlyInput.fwd then dir=dir+cf.LookVector end
        if cbFlyInput.bwd then dir=dir-cf.LookVector end
        if cbFlyInput.lft then dir=dir-cf.RightVector end
        if cbFlyInput.rgt then dir=dir+cf.RightVector end
        if cbFlyInput.up  then dir=dir+Vector3.new(0,1,0) end
        if cbFlyInput.dn  then dir=dir-Vector3.new(0,1,0) end
        if dir.Magnitude>0 then dir=dir.Unit end
        local bv2=hrp:FindFirstChild("CB_FlyBV"); local bg2=hrp:FindFirstChild("CB_FlyBG")
        if bv2 then bv2.Velocity=dir*cb.cbfly_speed end
        if bg2 then bg2.CFrame=cf end
    end)
end

local function cbStopFly()
    if cbFlyConn then cbFlyConn:Disconnect(); cbFlyConn=nil end
    local hrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        for _,n in ipairs({"CB_FlyBG","CB_FlyBV"}) do
            local o=hrp:FindFirstChild(n); if o then o:Destroy() end
        end
    end
    cbFlyGui.Enabled=false
end

