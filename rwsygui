-- ─── Yardımcı ─────────────────────────────────────────────────
local cb_esp = {}

local function cbW2S(pos)
    local v, on = camera:WorldToViewportPoint(pos)
    return Vector2.new(v.X, v.Y), on
end

local function cbRig(c)
    local h = c:FindFirstChildOfClass("Humanoid")
    if h and h.RigType == Enum.HumanoidRigType.R15 then return r15_bones end
    if c:FindFirstChild("Left Upper Arm") then return custom_bones end
    return r6_bones
end

local function cbIsVisible(part, char)
    local origin   = camera.CFrame.Position
    local target   = part.Position
    local dir      = (target - origin)
    local rp       = RaycastParams.new()
    rp.FilterType  = Enum.RaycastFilterType.Exclude
    rp.FilterDescendantsInstances = {player.Character or workspace, char}
    local result   = workspace:Raycast(origin, dir, rp)
    if not result then return true end
    return (result.Position - target).Magnitude < 1.5
end

local function cbCharVisible(c)
    local torso = c:FindFirstChild("UpperTorso") or c:FindFirstChild("Torso") or c:FindFirstChild("HumanoidRootPart")
    if torso and cbIsVisible(torso, c) then return true end
    local head = c:FindFirstChild("Head")
    if head and cbIsVisible(head, c) then return true end
    return false
end

local function cbMakeLine()
    local l = Drawing.new("Line")
    l.Visible=false; l.Thickness=cb.skeleton_thickness
    l.Color=cb.skel_visible_col; l.Transparency=cb.skeleton_transp
    return l
end
local function cbMakeSquare()
    local s = Drawing.new("Square"); s.Visible=false; s.Filled=false; return s
end
local function cbMakeText()
    local t = Drawing.new("Text")
    t.Visible=false; t.Center=true; t.Outline=true; t.Font=2
    return t
end

local function cbClean(p)
    local d = cb_esp[p]; if not d then return end
    if d.lines then
        for _, b in pairs(d.lines) do
            if b.line then b.line:Remove() end
        end
    end
    for _, k in ipairs({"box","box_ol","box_fill","hpbg","hp","name","dist","tracer","tracer_ol"}) do
        if d[k] then d[k]:Remove() end
    end
    cb_esp[p] = nil
end

local function cbBuild(p)
    if not p:IsA("Player") or not cb.esp_active then return end
    if cb.team_check and p.Team == player.Team and p.Team ~= nil then cbClean(p); return end
    cbClean(p)

    local c = p.Character; if not c then return end
    local h = c:FindFirstChildOfClass("Humanoid")
    if not h or h.Health <= 0 then return end
    local hrp = c:FindFirstChild("HumanoidRootPart"); if not hrp then return end

    local lines = {}
    if cb.skeleton_enabled then
        for _, bone in ipairs(cbRig(c)) do
            local p1 = c:FindFirstChild(bone[1])
            local p2 = c:FindFirstChild(bone[2])
            if p1 and p2 then
                table.insert(lines, {line=cbMakeLine(), p1=p1, p2=p2})
            end
        end
    end

    local box      = cbMakeSquare()
    local box_ol   = cbMakeSquare()
    local box_fill = cbMakeSquare()
    local hpbg     = cbMakeSquare()
    local hp       = cbMakeSquare()
    local name_t   = cbMakeText()
    local dist_t   = cbMakeText()
    local tracer   = cbMakeLine()
    local tracer_ol= cbMakeLine()

    box_ol.Thickness  = cb.box_thickness + 1
    box_ol.Color      = Color3.new(0,0,0)
    box_fill.Filled   = true
    hpbg.Filled       = true
    hpbg.Color        = Color3.new(0,0,0)
    hpbg.Transparency = 0.5
    hp.Filled         = true
    tracer_ol.Color   = Color3.new(0,0,0)

    cb_esp[p] = {
        lines=lines, character=c, humanoid=h,
        box=box, box_ol=box_ol, box_fill=box_fill,
        hpbg=hpbg, hp=hp, name=name_t, dist=dist_t,
        tracer=tracer, tracer_ol=tracer_ol,
    }
end

local function cbGetBounds(c)
    local hrp = c:FindFirstChild("HumanoidRootPart"); if not hrp then return nil end
    local sz = hrp.Size; local cf = hrp.CFrame; local corners = {}
    for _, off in ipairs({
        Vector3.new( sz.X/2, sz.Y/2, sz.Z/2), Vector3.new(-sz.X/2, sz.Y/2, sz.Z/2),
        Vector3.new( sz.X/2,-sz.Y/2, sz.Z/2), Vector3.new(-sz.X/2,-sz.Y/2, sz.Z/2),
        Vector3.new( sz.X/2, sz.Y/2,-sz.Z/2), Vector3.new(-sz.X/2, sz.Y/2,-sz.Z/2),
        Vector3.new( sz.X/2,-sz.Y/2,-sz.Z/2), Vector3.new(-sz.X/2,-sz.Y/2,-sz.Z/2),
    }) do
        local sp, on = cbW2S(cf:PointToWorldSpace(off))
        if on then table.insert(corners, sp) end
    end
    if #corners == 0 then return nil end
    local minX,maxX,minY,maxY = math.huge,-math.huge,math.huge,-math.huge
    for _, co in pairs(corners) do
        minX=math.min(minX,co.X); maxX=math.max(maxX,co.X)
        minY=math.min(minY,co.Y); maxY=math.max(maxY,co.Y)
    end
    return {
        topLeft = Vector2.new(minX,minY),
        size    = Vector2.new(maxX-minX, maxY-minY),
        center  = Vector2.new((minX+maxX)/2, (minY+maxY)/2),
    }
end

local HIDE_KEYS = {"box","box_ol","box_fill","hpbg","hp","name","dist","tracer","tracer_ol"}
local function cbHideAll(d)
    for _, k in ipairs(HIDE_KEYS) do if d[k] then d[k].Visible=false end end
    if d.lines then for _, b in pairs(d.lines) do b.line.Visible=false end end
end

local function cbUpdateESP()
    for p, d in pairs(cb_esp) do
        local c = d.character
        local h = d.humanoid
        if not c or not c.Parent or not h then cbClean(p); continue end
        if p.Character and p.Character ~= c then
            cbBuild(p); continue
        end
        if h.Health <= 0 then cbHideAll(d); continue end

        local hrp = c:FindFirstChild("HumanoidRootPart")
        if not hrp then cbHideAll(d); continue end

        local visible = cbCharVisible(c)
        local skelCol = visible and cb.skel_visible_col or cb.skel_hidden_col

        if cb.skeleton_enabled and d.lines and #d.lines > 0 then
            for _, b in ipairs(d.lines) do
                local p1, p2 = b.p1, b.p2
                if p1 and p1.Parent and p2 and p2.Parent then
                    local s1, on1 = cbW2S(p1.Position)
                    local s2, on2 = cbW2S(p2.Position)
                    if on1 and on2 then
                        b.line.From        = s1
                        b.line.To          = s2
                        b.line.Color       = skelCol
                        b.line.Thickness   = cb.skeleton_thickness
                        b.line.Transparency= cb.skeleton_transp
                        b.line.Visible     = true
                    else
                        b.line.Visible = false
                    end
                else
                    b.line.Visible = false
                end
            end
        else
            if d.lines then for _, b in pairs(d.lines) do b.line.Visible=false end end
        end

        local bounds = cbGetBounds(c)
        if bounds then
            if cb.box_enabled then
                d.box_ol.Position = bounds.topLeft - Vector2.new(1,1)
                d.box_ol.Size     = bounds.size    + Vector2.new(2,2)
                d.box_ol.Thickness= cb.box_thickness + 1
                d.box_ol.Visible  = true

                d.box_fill.Position    = bounds.topLeft
                d.box_fill.Size        = bounds.size
                d.box_fill.Color       = cb.box_fill_color
                d.box_fill.Transparency= cb.box_fill_transp
                d.box_fill.Visible     = cb.box_filled

                d.box.Position  = bounds.topLeft
                d.box.Size      = bounds.size
                d.box.Color     = cb.box_color
                d.box.Thickness = cb.box_thickness
                d.box.Visible   = true
            else
                d.box.Visible=false; d.box_ol.Visible=false; d.box_fill.Visible=false
            end

            if cb.hpbar_enabled then
                local bw  = 3
                local bh  = bounds.size.Y
                local pct = math.clamp(h.Health / math.max(h.MaxHealth, 1), 0, 1)
                local cur = bh * pct
                d.hpbg.Position = Vector2.new(bounds.topLeft.X - bw - 3, bounds.topLeft.Y)
                d.hpbg.Size     = Vector2.new(bw, bh)
                d.hpbg.Visible  = true
                d.hp.Position   = Vector2.new(bounds.topLeft.X - bw - 3, bounds.topLeft.Y + bh - cur)
                d.hp.Size       = Vector2.new(bw, cur)
                d.hp.Color      = cb.hp_color_high:Lerp(cb.hp_color_low, 1 - pct)
                d.hp.Visible    = true
            else
                d.hp.Visible=false; d.hpbg.Visible=false
            end

            if cb.name_enabled then
                d.name.Text        = p.DisplayName
                d.name.Position    = Vector2.new(bounds.center.X, bounds.topLeft.Y - 15)
                d.name.Color       = cb.name_color
                d.name.Size        = cb.name_size
                d.name.Visible     = true
            else d.name.Visible=false end

            if cb.dist_enabled then
                local dist = (hrp.Position - camera.CFrame.Position).Magnitude
                d.dist.Text     = string.format("%d studs", math.floor(dist))
                d.dist.Position = Vector2.new(bounds.center.X, bounds.topLeft.Y + bounds.size.Y + 2)
                d.dist.Color    = cb.dist_color
                d.dist.Size     = cb.dist_size
                d.dist.Visible  = true
            else d.dist.Visible=false end
        else
            d.box.Visible=false; d.box_ol.Visible=false; d.box_fill.Visible=false
            d.hp.Visible=false;  d.hpbg.Visible=false
            d.name.Visible=false; d.dist.Visible=false
        end

        if cb.tracer_enabled then
            local sp, on = cbW2S(hrp.Position)
            if on then
                local vp   = camera.ViewportSize
                local from
                if     cb.tracer_from == "Bottom" then from = Vector2.new(vp.X/2, vp.Y)
                elseif cb.tracer_from == "Middle" then from = Vector2.new(vp.X/2, vp.Y/2)
                elseif cb.tracer_from == "Top"    then from = Vector2.new(vp.X/2, 0)
                else                                   from = Vector2.new(mouse.X, mouse.Y) end
                d.tracer_ol.From       = from; d.tracer_ol.To = sp
                d.tracer_ol.Thickness  = cb.tracer_thickness + 2
                d.tracer_ol.Transparency = cb.tracer_transp * 0.5
                d.tracer_ol.Visible    = (cb.tracer_thickness > 1)
                d.tracer.From          = from; d.tracer.To = sp
                d.tracer.Color         = cb.tracer_color
                d.tracer.Thickness     = cb.tracer_thickness
                d.tracer.Transparency  = cb.tracer_transp
                d.tracer.Visible       = true
            else
                d.tracer.Visible=false; d.tracer_ol.Visible=false
            end
        else
            d.tracer.Visible=false; d.tracer_ol.Visible=false
        end
    end
end

local function cbRefreshAll()
    for p, _ in pairs(cb_esp) do cbClean(p) end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then cbBuild(p) end
    end
end

