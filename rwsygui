local function checkRow(parent, text, default, order, onChange)
    local row = frame(parent, UDim2.new(1,0,0,46), UDim2.new(0,0,0,0), C.row_a)
    row.LayoutOrder = order or 0; corner(row, 5)
    lbl(row, text, UDim2.new(1,-62,1,0), UDim2.new(0,12,0,0), C.txt_lbl, 13)
