local staticJoy = { enabled=false, lockedPos=nil, conn=nil, guiConn=nil }

local function staticJoyApply()
    if staticJoy.conn then staticJoy.conn:Disconnect(); staticJoy.conn=nil end
    local ok,err=pcall(function()
        local touchGui=player.PlayerGui:WaitForChild("TouchGui",4)
        local ctrlFrame=touchGui:WaitForChild("TouchControlFrame",4)
