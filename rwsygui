    local function setVal(v)
        checked=v; box.BackgroundColor3=v and C.chk_on or C.chk_off
        chkL.Text=v and "✓" or ""
    end
    ov.MouseButton1Click:Connect(function()
        setVal(not checked); if onChange then onChange(checked) end
    end)
    return row, setVal
end

local function dropdown(parent, lbl_text, options, default, order, onChange)
    local row = frame(parent, UDim2.new(1,0,0,46), UDim2.new(0,0,0,0), C.row_b)
    row.LayoutOrder = order or 0; corner(row, 5)
    lbl(row, lbl_text, UDim2.new(0.5,0,1,0), UDim2.new(0,12,0,0), C.txt_lbl, 13)
    local selected = default or options[1]
    local vBtn = mkbtn(row, selected.."  ▼",
        UDim2.new(0.44,0,0,34), UDim2.new(0.54,0,0.5,-17), C.input_bg, C.txt, 12)
    stroke(vBtn, 1, C.border)

    local listH = #options * 38
    local dropF = Instance.new("Frame")
    dropF.Size = UDim2.new(0,200,0,listH); dropF.BackgroundColor3 = C.input_bg
    dropF.BorderSizePixel = 0; dropF.ZIndex = 101; dropF.Visible = false
    dropF.ClipsDescendants = false; dropF.Parent = SG
    corner(dropF, 5); stroke(dropF, 1.5, C.accent)

    local dl = Instance.new("UIListLayout")
    dl.SortOrder = Enum.SortOrder.LayoutOrder; dl.Parent = dropF

    local function closeDD()
        dropF.Visible = false
        if activeDropdown == dropF then activeDropdown = nil end
        ddClose.Visible = false; vBtn.Text = selected.."  ▼"
    end

    for i, opt in ipairs(options) do
        local ob = mkbtn(dropF, opt, UDim2.new(1,0,0,38), UDim2.new(0,0,0,0),
            Color3.fromRGB(18,22,30), C.txt, 13)
        ob.LayoutOrder = i; ob.ZIndex = 102
        ob.MouseButton1Click:Connect(function()
            selected = opt; closeDD(); if onChange then onChange(opt) end
        end)
    end

    vBtn.MouseButton1Click:Connect(function()
        if activeDropdown and activeDropdown ~= dropF then
            activeDropdown.Visible = false; activeDropdown = nil
        end
        if dropF.Visible then closeDD(); return end
        local ap = vBtn.AbsolutePosition; local as = vBtn.AbsoluteSize
        local vps = camera.ViewportSize
        local lx = ap.X; local ly = ap.Y + as.Y + 2
        if ly + listH > vps.Y - 10 then ly = ap.Y - listH - 2 end
        if lx + 200 > vps.X - 4 then lx = vps.X - 204 end
        dropF.Position = UDim2.new(0,lx,0,ly)
        dropF.Size = UDim2.new(0, math.max(as.X,200), 0, listH)
        dropF.Visible = true; activeDropdown = dropF; ddClose.Visible = true
        vBtn.Text = selected.."  ▲"
    end)
    return row
end

local function sliderRow(parent, lbl_text, minV, maxV, defV, order, onChange)
    local row = frame(parent, UDim2.new(1,0,0,54), UDim2.new(0,0,0,0), C.row_a)
    row.LayoutOrder = order or 0; corner(row, 5)
    lbl(row, lbl_text, UDim2.new(0.65,0,0,22), UDim2.new(0,12,0,4), C.txt_lbl, 13)
    local valL = lbl(row, tostring(defV), UDim2.new(0.3,0,0,22),
        UDim2.new(0.68,0,0,4), C.accent, 13, Enum.TextXAlignment.Right)
    local track = frame(row, UDim2.new(1,-24,0,10), UDim2.new(0,12,0,34), C.sl_bg)
    corner(track, 5)
    local pct = (defV-minV)/(maxV-minV)
    local fill = frame(track, UDim2.new(pct,0,1,0), UDim2.new(0,0,0,0), C.sl_fill); corner(fill,5)
    local knob = frame(track, UDim2.new(0,20,0,20), UDim2.new(pct,0,0.5,-10), C.accent)
    corner(knob,10); stroke(knob,1.5,Color3.fromRGB(180,210,255))
    local sliding = false
    local function upd(absX)
        local p = math.clamp((absX-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        local v = math.round((minV+p*(maxV-minV))*100)/100
        fill.Size=UDim2.new(p,0,1,0); knob.Position=UDim2.new(p,-10,0.5,-10)
        valL.Text=tostring(v); if onChange then onChange(v) end
    end
    track.InputBegan:Connect(function(inp) if isTouch(inp) then sliding=true; upd(inp.Position.X) end end)
    UserInputService.InputChanged:Connect(function(inp)
        if sliding and (inp.UserInputType==Enum.UserInputType.MouseMovement
            or inp.UserInputType==Enum.UserInputType.Touch) then upd(inp.Position.X) end
    end)
    UserInputService.InputEnded:Connect(function(inp) if isTouch(inp) then sliding=false end end)
    return row
end

