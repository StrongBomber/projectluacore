-- Her legit_aim_interval saniyede bir havuzdan rastgele bir bölge seçer
-- ve bunu cb.aim_part olarak atar; böylece normal aimbot bu bölgeyi hedefler.
-- Seçilen bölge, UI'deki bilgi satırında da güncellenir.

local legitAimPartLabel = nil  -- aşağıda UI oluşturulduktan sonra atanır

local function cbPickRandomPart()
    local pool = cb.legit_aim_parts
    -- Havuzdan rastgele bir index seç, mevcut bölgeyle aynı olmaması için
    -- (tek elemanlı havuzda kontrol atlatılır)
    local idx
    if #pool <= 1 then
        idx = 1
    else
        repeat
            idx = math.random(1, #pool)
        until pool[idx] ~= cb.legit_aim_current
    end
    cb.legit_aim_current = pool[idx]
    cb.aim_part          = pool[idx]
    -- UI etiketini güncelle
    if legitAimPartLabel then
        legitAimPartLabel.Text = "🎲 Aktif Bölge:  " .. cb.legit_aim_current
    end
end

