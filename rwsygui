local function startFly()
    local hrp=getHRP(); if not hrp then return end
    local old1=hrp:FindFirstChild("RaiFlyBG"); local old2=hrp:FindFirstChild("RaiFlyBV")
    if old1 then old1:Destroy() end; if old2 then old2:Destroy() end
    local bg=Instance.new("BodyGyro")
    bg.Name="RaiFlyBG"; bg.MaxTorque=Vector3.new(9e9,9e9,9e9); bg.CFrame=hrp.CFrame; bg.D=50; bg.P=1e5; bg.Parent=hrp
    local bv=Instance.new("BodyVelocity")
    bv.Name="RaiFlyBV"; bv.MaxForce=Vector3.new(9e9,9e9,9e9); bv.Velocity=Vector3.zero; bv.Parent=hrp
    if S.flyConn then S.flyConn:Disconnect() end
    S.flyConn=RunService.Heartbeat:Connect(function()
        if not S.fly then
            S.flyConn:Disconnect(); S.flyConn=nil
            local b1=hrp:FindFirstChild("RaiFlyBG"); local b2=hrp:FindFirstChild("RaiFlyBV")
            if b1 then b1:Destroy() end; if b2 then b2:Destroy() end; return
        end
        local dir=Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.Up) then dir=dir+camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) or UserInputService:IsKeyDown(Enum.KeyCode.Down) then dir=dir-camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Left) then dir=dir-camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.Right) then dir=dir+camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then dir=dir+Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then dir=dir-Vector3.new(0,1,0) end
        if dir.Magnitude>0 then dir=dir.Unit end
        local b1=hrp:FindFirstChild("RaiFlyBV"); local b2=hrp:FindFirstChild("RaiFlyBG")
        if b1 then b1.Velocity=dir*S.flySpeed end; if b2 then b2.CFrame=camera.CFrame end
    end)
end

