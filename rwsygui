local function cbGetClosest()
    local closest, closestDist = nil, cb.aim_fov
    local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    for _, p in ipairs(Players:GetPlayers()) do
        if p == player then continue end
        if cb.team_check and p.Team == player.Team and p.Team ~= nil then continue end
        local c = p.Character; if not c then continue end
        local h = c:FindFirstChildOfClass("Humanoid"); if not h or h.Health <= 0 then continue end
        local part = c:FindFirstChild(cb.aim_part); if not part then continue end
        if cb.aim_vischeck and not cbIsVisible(part, c) then continue end
        local sp, on = cbW2S(part.Position); if not on then continue end
        local dist = (sp - center).Magnitude
        if dist < closestDist then closestDist=dist; closest=p end
    end
    return closest
end

local function cbAimAt(target)
    if not target or not target.Character then return end
    local part = target.Character:FindFirstChild(cb.aim_part); if not part then return end
    local dir  = (part.Position - camera.CFrame.Position).Unit
    local tgt  = CFrame.new(camera.CFrame.Position, camera.CFrame.Position + dir)
    camera.CFrame = camera.CFrame:Lerp(tgt, 1 / cb.aim_smooth)
end

