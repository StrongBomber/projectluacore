local function cbGetBounds(c)
    local hrp=c:FindFirstChild("HumanoidRootPart"); if not hrp then return nil end
    local sz=hrp.Size; local cf=hrp.CFrame; local corners={}
    for _,off in ipairs({
        Vector3.new(sz.X/2,sz.Y/2,sz.Z/2),Vector3.new(-sz.X/2,sz.Y/2,sz.Z/2),
        Vector3.new(sz.X/2,-sz.Y/2,sz.Z/2),Vector3.new(-sz.X/2,-sz.Y/2,sz.Z/2),
        Vector3.new(sz.X/2,sz.Y/2,-sz.Z/2),Vector3.new(-sz.X/2,sz.Y/2,-sz.Z/2),
        Vector3.new(sz.X/2,-sz.Y/2,-sz.Z/2),Vector3.new(-sz.X/2,-sz.Y/2,-sz.Z/2),
    }) do
        local sp,on=cbW2S(cf:PointToWorldSpace(off))
        if on then table.insert(corners,sp) end
    end
    if #corners==0 then return nil end
    local minX,maxX,minY,maxY=math.huge,-math.huge,math.huge,-math.huge
    for _,co in pairs(corners) do
        minX=math.min(minX,co.X); maxX=math.max(maxX,co.X)
        minY=math.min(minY,co.Y); maxY=math.max(maxY,co.Y)
    end
    return{
        topLeft=Vector2.new(minX,minY),
        size=Vector2.new(maxX-minX,maxY-minY),
        center=Vector2.new((minX+maxX)/2,(minY+maxY)/2),
    }
end

