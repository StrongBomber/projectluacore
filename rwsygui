local function cbMakeAdjustable(obj)
    local dragging,dragStart,startPos; local isPinching=false
    local c1=obj.InputBegan:Connect(function(inp)
        if not cbMobileActive then return end
        if inp.UserInputType==Enum.UserInputType.Touch
            or inp.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=true; dragStart=inp.Position; startPos=obj.Position
            inp.Changed:Connect(function()
                if inp.UserInputState==Enum.UserInputState.End then
                    dragging=false; isPinching=false
                end
            end)
        end
    end)
    local c2=UserInputService.InputChanged:Connect(function(inp)
        if dragging and not isPinching and
            (inp.UserInputType==Enum.UserInputType.MouseMovement
             or inp.UserInputType==Enum.UserInputType.Touch) then
            local d=inp.Position-dragStart
            obj.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,
                startPos.Y.Scale,startPos.Y.Offset+d.Y)
        end
    end)
    local c3=UserInputService.TouchPinch:Connect(function(touches,scale,velocity,state)
        if not cbMobileActive then return end
        if state==Enum.UserInputState.Begin then
            local center=(touches[1]+touches[2])/2
            local found=player.PlayerGui:GetGuiObjectsAtPosition(center.X,center.Y)
            for _,fo in pairs(found) do
                if fo==obj then
                    isPinching=true
                    obj:SetAttribute("_pinchW",obj.Size.X.Offset)
                    obj:SetAttribute("_pinchH",obj.Size.Y.Offset)
                    break
                end
            end
        elseif state==Enum.UserInputState.Change and isPinching then
            local pw=obj:GetAttribute("_pinchW") or obj.Size.X.Offset
            local ph=obj:GetAttribute("_pinchH") or obj.Size.Y.Offset
            obj.Size=UDim2.new(obj.Size.X.Scale,math.max(50,pw*scale),
                obj.Size.Y.Scale,math.max(30,ph*scale))
        end
    end)
    table.insert(cbMobileConns,c1)
    table.insert(cbMobileConns,c2)
    table.insert(cbMobileConns,c3)
end

