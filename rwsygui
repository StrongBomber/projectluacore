    sc.Visible = idx==1; sc.ZIndex = 11; sc.Parent = CA
    tabPanels[idx] = sc

    local pad = Instance.new("UIPadding")
    pad.PaddingTop=UDim.new(0,10); pad.PaddingLeft=UDim.new(0,10)
    pad.PaddingRight=UDim.new(0,14); pad.PaddingBottom=UDim.new(0,16)
    pad.Parent = sc

    local lay = Instance.new("UIListLayout")
    lay.SortOrder = Enum.SortOrder.LayoutOrder; lay.Padding = UDim.new(0,8)
    lay.Parent = sc
    return sc
end

