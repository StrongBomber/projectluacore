-- ══════════════════════════════════════
local FOV_ARROWS = {}  -- [playerName] = { lL, lR, label }

local function fovArrowCleanAll()
    for pName, drawState in pairs(FOV_ARROWS) do
        drawState.lShaft:Remove()
        drawState.lWL:Remove()
        drawState.lWR:Remove()
        drawState.label:Remove()
        FOV_ARROWS[pName] = nil
    end
end

local function updateFOVArrows()
    if not FOV_ARROW_STATE.enabled then
        fovArrowCleanAll()
        return
    end

    local center = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    local fovR   = SA.enabled and SA.fov or cb.aim_fov

    for _, p in ipairs(Players:GetPlayers()) do
        if p == player then continue end
        if cb.team_check and p.Team == player.Team and p.Team ~= nil then continue end

        local character = p.Character
        local hrp       = character and character:FindFirstChild("HumanoidRootPart")
        local humanoid  = character and character:FindFirstChildOfClass("Humanoid")

        if hrp and humanoid and humanoid.Health > 0 then
            -- Mesafe: normal ESP ile birebir aynı formül
            local dist = math.floor((hrp.Position - camera.CFrame.Position).Magnitude)

            -- W2S
            local screenPos = camera:WorldToViewportPoint(hrp.Position)
            local screenVec = Vector2.new(screenPos.X, screenPos.Y)

            -- onScreen kontrolü: kameranın önünde (Z>0) VE ekran sınırları içinde
            local vp = camera.ViewportSize
            local onScreen = (screenPos.Z > 0)
                and screenPos.X >= 0 and screenPos.X <= vp.X
                and screenPos.Y >= 0 and screenPos.Y <= vp.Y

            if onScreen then
                -- Ekranda görünüyor: oku gizle
                if FOV_ARROWS[p.Name] then
                    FOV_ARROWS[p.Name].lShaft.Visible = false
                    FOV_ARROWS[p.Name].lWL.Visible    = false
                    FOV_ARROWS[p.Name].lWR.Visible    = false
                    FOV_ARROWS[p.Name].label.Visible  = false
                end
            else
                -- FOV dışında: oku oluştur veya güncelle
                if not FOV_ARROWS[p.Name] then
                    local lShaft = Drawing.new("Line")  -- ok gövdesi (düz çizgi)
                    local lWL    = Drawing.new("Line")  -- sol kanatçık (uçta)
                    local lWR    = Drawing.new("Line")  -- sağ kanatçık (uçta)
                    local label  = Drawing.new("Text")
                    lShaft.Thickness   = 20
                    lWL.Thickness      = 20
                    lWR.Thickness      = 20
                    label.Size         = 15
                    label.Center       = true
                    label.Outline      = true
                    label.OutlineColor = Color3.fromRGB(0, 0, 0)
                    FOV_ARROWS[p.Name] = { lShaft=lShaft, lWL=lWL, lWR=lWR, label=label }
                end

                local d = FOV_ARROWS[p.Name]

                -- Renk güncelle
                d.lShaft.Color = FOV_ARROW_STATE.arrowColor
                d.lWL.Color    = FOV_ARROW_STATE.arrowColor
                d.lWR.Color    = FOV_ARROW_STATE.arrowColor
                d.label.Color  = FOV_ARROW_STATE.textColor

                -- Yön: PointToObjectSpace ile kamera local space
                local offset = camera.CFrame:PointToObjectSpace(hrp.Position)
                local norm   = Vector2.new(offset.X, -offset.Y)
                if norm.Magnitude > 0 then
                    norm = norm.Unit
                else
                    norm = Vector2.new(0, -1)
                end
                local perp = Vector2.new(-norm.Y, norm.X)

                -- ➔ Ok geometrisi:
                --   tail  = ok kuyruğu (FOV çemberinden içe 28px)
                --   tip   = ok ucu (FOV çemberi üzerinde)
                --   sol/sağ kanatçık: uçtan geri + yana (küçük, sadece uçta)
                local tip  = center + norm * fovR
                local tail = tip - norm * 36             -- gövde uzunluğu 36px

                local wingLen  = 16   -- kanatçık uzunluğu
                local wingOpen = 10   -- kanatçık açıklığı (yan)

                local wingL = tip - norm * wingLen - perp * wingOpen
                local wingR = tip - norm * wingLen + perp * wingOpen

                -- Gövde: tail → tip
                d.lShaft.From = tail; d.lShaft.To = tip; d.lShaft.Visible = true
                -- Sol kanatçık: wingL → tip
                d.lWL.From = wingL;   d.lWL.To = tip;   d.lWL.Visible = true
                -- Sağ kanatçık: wingR → tip
                d.lWR.From = wingR;   d.lWR.To = tip;   d.lWR.Visible = true

                -- Etiket: ok ucunun 16px ötesine
                d.label.Text     = tostring(dist) .. " studs"
                d.label.Position = tip + norm * 16
                d.label.Visible  = true
            end
        else
            -- Oyuncu öldü/yok: temizle
            if FOV_ARROWS[p.Name] then
                FOV_ARROWS[p.Name].lShaft:Remove()
                FOV_ARROWS[p.Name].lWL:Remove()
                FOV_ARROWS[p.Name].lWR:Remove()
                FOV_ARROWS[p.Name].label:Remove()
                FOV_ARROWS[p.Name] = nil
            end
        end
    end

    -- Oyundan çıkan oyuncuları temizle
    for pName in pairs(FOV_ARROWS) do
        if not Players:FindFirstChild(pName) then
            FOV_ARROWS[pName].lShaft:Remove()
            FOV_ARROWS[pName].lWL:Remove()
            FOV_ARROWS[pName].lWR:Remove()
            FOV_ARROWS[pName].label:Remove()
            FOV_ARROWS[pName] = nil
        end
    end
end

