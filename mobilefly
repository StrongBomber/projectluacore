local function SaveData()
    if writefile then
        local data = {
            lightMode = isLightMode,
            mini = minimized,
            rgb = isRGBMode,
            trailIdx = currentTrailColorIndex,
            spdTxt = SpeedInput and SpeedInput.Text or "25",
            shfTxt = ShiftInput and ShiftInput.Text or ""
        }
        pcall(function() writefile(saveFileName, HttpService:JSONEncode(data)) end)
    end
end

pcall(function()
    if readfile and isfile and isfile(saveFileName) then
        local result = readfile(saveFileName)
        local loadedData = HttpService:JSONDecode(result)
        
        if loadedData then
            if loadedData.lightMode then
                isLightMode = true
                ThemeBtn.Text = "☀️"
                MainFrame.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
                ThemeBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 0)
                Title.TextColor3 = Color3.fromRGB(30, 30, 30)
                ShiftTitle.TextColor3 = Color3.fromRGB(80, 80, 80)
                FlyOptionsTitle.TextColor3 = Color3.fromRGB(80, 80, 80)
                SpeedTitle.TextColor3 = Color3.fromRGB(80, 80, 80)
                ExtraOptionsTitle.TextColor3 = Color3.fromRGB(80, 80, 80)
                TrailTitle.TextColor3 = Color3.fromRGB(30, 30, 30)
            end
            
            if loadedData.spdTxt then 
                SpeedInput.Text = loadedData.spdTxt 
                speed = tonumber(loadedData.spdTxt) or 25 
            end
            if loadedData.shfTxt then 
                ShiftInput.Text = loadedData.shfTxt 
            end
            
            if loadedData.trailIdx then
                currentTrailColorIndex = loadedData.trailIdx
                local cData = trailColors[currentTrailColorIndex]
                TrailColorBtn.BackgroundColor3 = cData.color
                TrailColorBtn.TextColor3 = cData.textColor
                TrailColorBtn.Text = "color: " .. cData.name
            end
            
            if loadedData.rgb then
                isRGBMode = true
                RGBBtn.Text = "🌈"
                TrailTitle.TextTransparency = 0
                TrailColorBtn.BackgroundTransparency = 0
                TrailColorBtn.TextTransparency = 0
                LeftTrailBtn.TextTransparency = 0 
                RightTrailBtn.TextTransparency = 0 
                
                local hue = 0
                rgbConnection = RunService.RenderStepped:Connect(function(dt)
                    hue = (hue + dt * 0.3) % 1
                    RGBBtn.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
                end)
            end
            
            if loadedData.mini then
                minimized = true
                MiniBtn.Text = "+"
                MiniBtn.TextColor3 = Color3.fromRGB(0, 255, 100)
                MainFrame.Size = UDim2.new(0, 180, 0, 30)
            else
                minimized = false
                if isRGBMode then
                    MainFrame.Size = UDim2.new(0, 180, 0, 395)
                else
                    MainFrame.Size = UDim2.new(0, 180, 0, 365)
                end
            end
        end
    end
end)

local limitNotifCooldown = false

local function applyCharacterLimit(box)
    box:GetPropertyChangedSignal("Text"):Connect(function()
        if #box.Text > 6 then
            box.Text = string.sub(box.Text, 1, 6)
            
            if not limitNotifCooldown then
