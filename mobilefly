local cachedControls
local function getAnalogMagnitude()
    if not cachedControls then
        pcall(function()
            cachedControls = require(LocalPlayer.PlayerScripts:FindFirstChild("PlayerModule")):GetControls()
        end)
    end
    if cachedControls then
        local moveVec = cachedControls:GetMoveVector()
        if moveVec and moveVec.Magnitude > 0 then
            return math.clamp(moveVec.Magnitude, 0, 1)
        end
    end
    return 1 
end

local function toggleFly(state, isGuiSource)
    flying = state
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    local cam = workspace.CurrentCamera
    local animateScript = char:FindFirstChild("Animate") 
    local tInfo = TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    
    if flying then
        if animateScript then animateScript.Disabled = true end
        if hum then
            hum.PlatformStand = true 
            local animator = hum:FindFirstChildOfClass("Animator") or hum
            for _, track in pairs(animator:GetPlayingAnimationTracks()) do track:Stop() end
        end
        if isGuiSource then
            TweenService:Create(FlyBtn, tInfo, {BackgroundColor3 = Color3.fromRGB(200, 50, 50)}):Play()
            task.spawn(function()
                TweenService:Create(FlyBtn, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
                task.wait(0.2)
                FlyBtn.Text = "DISABLE FLY"
                TweenService:Create(FlyBtn, TweenInfo.new(0.2), {TextTransparency = 0}):Play()
            end)
        end
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then originalCollisions[part] = part.CanCollide end
        end
        lvAttachment = Instance.new("Attachment", root)
        bv = Instance.new("LinearVelocity", root)
        bg = Instance.new("AlignOrientation", root)
        bv.Attachment0 = lvAttachment
        bv.MaxForce = math.huge
        bv.RelativeTo = Enum.ActuatorRelativeTo.World
        bv.VectorVelocity = Vector3.new(0, 0, 0) 
        bg.Mode = Enum.OrientationAlignmentMode.OneAttachment
        bg.Attachment0 = lvAttachment
        bg.MaxTorque = math.huge
        bg.Responsiveness = 14 
        bg.RigidityEnabled = false 
        updateTrailNow()
        flyConnection = RunService.RenderStepped:Connect(function()
            if not flying or not root or not hum then if flyConnection then flyConnection:Disconnect() end return end
            hum:ChangeState(Enum.HumanoidStateType.Physics)
            hum.PlatformStand = true 
            bg.CFrame = cam.CFrame
            local moveDir = hum.MoveDirection
            local targetVelocity = Vector3.new(0, 0, 0)
            if moveDir.Magnitude > 0 then
                local analogMagnitude = getAnalogMagnitude() 
                local camY = select(2, cam.CFrame:ToEulerAnglesYXZ())
                local flatRot = CFrame.Angles(0, camY, 0)
                local localInput = flatRot:VectorToObjectSpace(moveDir)
                targetVelocity = cam.CFrame:VectorToWorldSpace(localInput) * (speed * analogMagnitude)
            end
            bv.VectorVelocity = bv.VectorVelocity:Lerp(targetVelocity, 0.18) 
        end)
        noclipConnection = RunService.Stepped:Connect(function()
            if not flying or not char then if noclipConnection then noclipConnection:Disconnect() end return end
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    if noclipEnabled then
                        part.CanCollide = false
                    else
                        if originalCollisions[part] ~= nil then
                            part.CanCollide = originalCollisions[part]
                        end
                    end
                end
            end
        end)
    else
        if animateScript then animateScript.Disabled = false end
        if isGuiSource then
            TweenService:Create(FlyBtn, tInfo, {BackgroundColor3 = accent_color}):Play()
            task.spawn(function()
                TweenService:Create(FlyBtn, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
                task.wait(0.2)
                FlyBtn.Text = "ENABLE FLY"
                TweenService:Create(FlyBtn, TweenInfo.new(0.2), {TextTransparency = 0}):Play()
            end)
        end
        if bv then bv:Destroy() end if bg then bg:Destroy() end if lvAttachment then lvAttachment:Destroy() end
        if flyConnection then flyConnection:Disconnect() end if noclipConnection then noclipConnection:Disconnect() end
        if trailInstance then
            trailInstance:Destroy() trailInstance = nil
            if att0 then att0:Destroy() att0 = nil end if att1 then att1:Destroy() att1 = nil end
        end
        if char and hum then
            hum.PlatformStand = false 
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    if originalCollisions[part] ~= nil then
                        part.CanCollide = originalCollisions[part]
                    end
                end
            end
        end
        originalCollisions = {}
    end
end

