local function onFocusLostPulse(box)
    SaveData() 
    if box.Text == "" or box.Text:match("^%s*$") then return end
    local originalSize, originalPos, originalColor = box.Size, box.Position, box.BackgroundColor3
    local tPulse = TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    local tReturn = TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
    local expand = TweenService:Create(box, tPulse, {
        Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset + 6, originalSize.Y.Scale, originalSize.Y.Offset + 4),
        Position = UDim2.new(originalPos.X.Scale, originalPos.X.Offset - 3, originalPos.Y.Scale, originalPos.Y.Offset - 2),
        BackgroundColor3 = Color3.fromRGB(70, 70, 70)
    })
    local contract = TweenService:Create(box, tReturn, {Size = originalSize, Position = originalPos, BackgroundColor3 = originalColor})
    expand:Play() expand.Completed:Connect(function() contract:Play() end)
end

ShiftInput.FocusLost:Connect(function() onFocusLostPulse(ShiftInput) end)
SpeedInput.FocusLost:Connect(function() onFocusLostPulse(SpeedInput) end)

