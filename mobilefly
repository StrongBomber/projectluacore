local function SafeNotification(title, text, duration)
    task.spawn(function()
        local success = false
        local tries = 0
        while not success and tries < 10 do
            success = pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = title,
                    Text = text,
                    Duration = duration or 5
                })
            end)
            if not success then 
                task.wait(1) 
                tries = tries + 1
            end
        end
    end)
end

