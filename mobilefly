local colorCooldown = false
local function changeTrailColorLogic(direction)
    if not isRGBMode or colorCooldown then return end
    colorCooldown = true
    local oldColor = trailColors[currentTrailColorIndex].color
    if direction == "next" then
        currentTrailColorIndex = currentTrailColorIndex + 1
        if currentTrailColorIndex > #trailColors then currentTrailColorIndex = 1 end
    elseif direction == "prev" then
        currentTrailColorIndex = currentTrailColorIndex - 1
        if currentTrailColorIndex < 1 then currentTrailColorIndex = #trailColors end
    end
    local cData = trailColors[currentTrailColorIndex]
    local targetColor = cData.color
    local tInfo = TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    TweenService:Create(TrailColorBtn, tInfo, {BackgroundColor3 = targetColor}):Play()
    TweenService:Create(TrailColorBtn, tInfo, {TextColor3 = cData.textColor}):Play()
    TrailColorBtn.Text = "color: " .. cData.name
    if cData.name == "none :(" then
        if trailInstance then
            trailInstance:Destroy() trailInstance = nil
            if att0 then att0:Destroy() att0 = nil end if att1 then att1:Destroy() att1 = nil end
        end
    elseif trailInstance and flying then
        task.spawn(function()
            local duration = 0.5
            local startTime = tick()
            while tick() - startTime < duration do
                local alpha = (tick() - startTime) / duration
                local lerpedColor = oldColor:Lerp(targetColor, alpha)
                if trailInstance then trailInstance.Color = ColorSequence.new(lerpedColor) end
                task.wait()
            end
            if trailInstance then trailInstance.Color = ColorSequence.new(targetColor) end
        end)
    else updateTrailNow() end
    SaveData() 
    task.wait(0.5)
    colorCooldown = false
end

