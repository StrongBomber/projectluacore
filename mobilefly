            if moveDir.Magnitude > 0 then
                local analogMagnitude = getAnalogMagnitude()
                local camY = select(2, cam.CFrame:ToEulerAnglesYXZ())
                local flatRot = CFrame.Angles(0, camY, 0)
                local localInput = flatRot:VectorToObjectSpace(moveDir)
                targetVelocity = cam.CFrame:VectorToWorldSpace(localInput) * (speed * analogMagnitude)
            end
            freeCamBv.VectorVelocity = freeCamBv.VectorVelocity:Lerp(targetVelocity, 0.18)
        end)
    else
        TweenService:Create(FreeCamBtn, tInfo, {BackgroundColor3 = Color3.fromRGB(200, 50, 50)}):Play()
        task.spawn(function()
            TweenService:Create(FreeCamBtn, tFade, {TextTransparency = 1}):Play()
            task.wait(0.2)
            FreeCamBtn.Text = "free cam 📷 : off ❌️"
            TweenService:Create(FreeCamBtn, tFade, {TextTransparency = 0}):Play()
        end)
        if freeCamConnection then freeCamConnection:Disconnect() end
        if freeCamPart then freeCamPart:Destroy() freeCamPart = nil end
        if originalMinZoom then LocalPlayer.CameraMinZoomDistance = originalMinZoom end
        if originalMaxZoom then LocalPlayer.CameraMaxZoomDistance = originalMaxZoom end
        cam.CameraSubject = hum
        if hrp then hrp.Anchored = false end
        if freeCamZoomed or cam.FieldOfView ~= originalFOV then
            freeCamZoomed = false
            TweenService:Create(cam, TweenInfo.new(0.3), {FieldOfView = originalFOV}):Play()
        end
    end
    task.wait(0.6)
    freeCamBtnCooldown = false
end)

