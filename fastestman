local function stopPool(pool)
    for _, snd in ipairs(pool) do if snd and snd.IsPlaying then snd:Stop() end end
end

local function playSmartSoundAI(soundType, timePos, baseVolume, characterVelocity)
    if not Settings.SoundsEnabled then return end
    local pool = (soundType == "Dash") and DashSoundPool or RunSoundPool
    if #pool == 0 then return end
    local index = (soundType == "Dash") and currentDashIndex or currentRunIndex
    local sound = pool[index]
    if soundType == "Dash" then currentDashIndex = (currentDashIndex % poolSize) + 1 else currentRunIndex = (currentRunIndex % poolSize) + 1 end
    if not sound then return end
    sound:Stop() sound.Volume = baseVolume * math.clamp(characterVelocity / 100, 0.5, 1.4) sound.PlaybackSpeed = math.clamp(1.0 + ((characterVelocity - 16) / 234) * 0.4, 0.85, 1.25) sound.TimePosition = timePos sound:Play()
end

local function playSonicBoomSound()
    if not Settings.SoundsEnabled or #SonicBoomPool == 0 then return end
    local sound = SonicBoomPool[currentBoomIndex] currentBoomIndex = (currentBoomIndex % #SonicBoomPool) + 1
    if sound then sound:Stop() sound.Volume = 4.5 sound.PlaybackSpeed = math.random(92, 103) / 100 sound:Play() end
    playSmartSoundAI("Dash", 0.0, 3.5, Settings.WalkSpeed)
end

local function playShockwaveSound()
    if not Settings.SoundsEnabled or os.clock() - lastShockwaveTime < 1.2 or #ShockwavePool == 0 then return end
    lastShockwaveTime = os.clock() stopPool(ShockwavePool)
    local sound = ShockwavePool[currentShockwaveIndex] currentShockwaveIndex = (currentShockwaveIndex % #ShockwavePool) + 1
    if sound then sound:Stop() sound.Volume = 4.0 sound.PlaybackSpeed = math.random(95, 105) / 100 sound:Play() end
end

local function playCrashWallSound()
