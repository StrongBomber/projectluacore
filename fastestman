local lastWallCrashTime, lastPlayerCrashTime = 0, 0
local function setupCharacterPhysicsSenses(char)
    local humanoid = char:WaitForChild("Humanoid", 5) local rootPart = char:WaitForChild("HumanoidRootPart", 5)
    if not humanoid or not rootPart then return end
    if Connections.TouchConnection then Connections.TouchConnection:Disconnect() end
    Connections.TouchConnection = humanoid.Touched:Connect(function(hit)
        if not Settings.Enabled or lastVelocityVec.Magnitude < 32 then return end
        if hit and hit.CanCollide and not hit:IsDescendantOf(char) and not hit:IsDescendantOf(VfxFolder) then
            if (hit.Position - rootPart.Position).Magnitude < 7 then
                local hm = hit:FindFirstAncestorOfClass("Model")
                if hm and Players:GetPlayerFromCharacter(hm) then if os.clock() - lastPlayerCrashTime > 0.4 then lastPlayerCrashTime = os.clock() playPlayerCrashSound() end
                else if hit.Anchored and os.clock() - lastWallCrashTime > 0.4 then lastWallCrashTime = os.clock() playCrashWallSound() end end
            end
        end
    end)
end

