local function tweenColor(obj, color) 
    TweenService:Create(obj, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {BackgroundColor3 = color}):Play() 
end

local function toggleWalkSpeed(state)
    Settings.Enabled = state 
    ToggleButton.Text = state and "SYSTEM ENGINE: OPERATIONAL" or "SYSTEM ENGINE: DISABLED"
    tweenColor(ToggleButton, state and NeonGreen or CrimsonRed)
    
    if Settings.Enabled then 
        tweenColor(MiniToggleBar, NeonGreen) MiniToggleBar.Text = "ENGINE ACTIVE" 
    else 
        tweenColor(MiniToggleBar, CrimsonRed) MiniToggleBar.Text = "ENGINE OFF" 
    end

    if Connections.SpeedLoop then Connections.SpeedLoop:Disconnect() Connections.SpeedLoop = nil end
    stopCustomAnim()

    if state then
        local wasHighSpeed, crossedSoundBarrier = false, false
        local lastGhostPos = Vector3.new()
        local initChar = LocalPlayer.Character
        local initRoot = initChar and initChar:FindFirstChild("HumanoidRootPart")
        if initRoot then lastGhostPos = initRoot.Position end

        Connections.SpeedLoop = RunService.RenderStepped:Connect(function(deltaTime)
            local char = LocalPlayer.Character
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            local rootPart = char and char:FindFirstChild("HumanoidRootPart")
            local CurrentCamera = workspace.CurrentCamera
            
            if humanoid and rootPart and humanoid.Health > 0 then
                local moveDir = humanoid.MoveDirection
                local velocityVec = rootPart.AssemblyLinearVelocity
                if velocityVec.Magnitude > 5 then lastVelocityVec = velocityVec end

                local targetSpeed = Settings.WalkSpeed
                if moveDir.Magnitude > 0.05 then
                    if Settings.MomentumEnabled then
                        actualSpeed = math.min(actualSpeed + (Settings.AccelerationRate * deltaTime), targetSpeed)
                    else
                        actualSpeed = targetSpeed
                    end
                else
                    if Settings.MomentumEnabled then
                        actualSpeed = math.max(actualSpeed - (Settings.AccelerationRate * 1.5 * deltaTime), 16)
                    else
                        actualSpeed = 16
                    end
                end

                if Settings.SpeedType == "Normal" then
                    stopCustomAnim()
                    humanoid.WalkSpeed = actualSpeed
                elseif Settings.SpeedType == "Bypass" then
                    humanoid.WalkSpeed = 16 
                    manageBypassAnimation(humanoid, moveDir)
                    
                    if moveDir.Magnitude > 0.05 and tostring(moveDir.X) ~= "nan" then
                        local flatMoveDir = Vector3.new(moveDir.X, 0, moveDir.Z).Unit
                        local bypassStepFactor = (actualSpeed - 16) * deltaTime
                        local currentPos = rootPart.Position
                        local targetX = currentPos.X + (flatMoveDir.X * bypassStepFactor)
                        local targetZ = currentPos.Z + (flatMoveDir.Z * bypassStepFactor)
                        local targetY = currentPos.Y 

                        local wallParams = RaycastParams.new()
                        wallParams.FilterType = Enum.RaycastFilterType.Exclude
                        wallParams.FilterDescendantsInstances = {char, CurrentCamera, VfxFolder}

                        if Settings.AutoStepEnabled then
                            local kneeHeightOffset = Vector3.new(0, -1, 0)
                            local stepRay = workspace:Raycast(currentPos + kneeHeightOffset, flatMoveDir * 2.2, wallParams)
                            if stepRay and stepRay.CanCollide then
                                local headHeightOffset = Vector3.new(0, Settings.StepHeight, 0)
                                local clearRay = workspace:Raycast(currentPos + headHeightOffset, flatMoveDir * 2.2, wallParams)
                                if not clearRay then
                                    targetY = targetY + 0.85
                                end
                            end
                        end

                        if not Settings.NoclipEnabled or actualSpeed <= Settings.NoclipThreshold then
                            local frontRay = workspace:Raycast(currentPos, flatMoveDir * (bypassStepFactor + 1.5), wallParams)
                            if frontRay and frontRay.CanCollide then
                                targetX = currentPos.X
                                targetZ = currentPos.Z
                            end
                        end
                        
                        rootPart.CFrame = CFrame.new(targetX, targetY, targetZ) * rootPart.CFrame.Rotation
                        rootPart.AssemblyLinearVelocity = Vector3.new(flatMoveDir.X * 16, rootPart.AssemblyLinearVelocity.Y, flatMoveDir.Z * 16)
                        lastVelocityVec = flatMoveDir * actualSpeed
                    else
                        rootPart.AssemblyLinearVelocity = Vector3.new(0, rootPart.AssemblyLinearVelocity.Y, 0)
                    end
                end
                
                if CurrentCamera then
                    local activeBaseFov = Settings.FovSystemEnabled and Settings.BaseFov or 70
                    if Settings.DynamicFovEnabled and moveDir.Magnitude > 0.05 then
                        local speedPercent = math.clamp((actualSpeed - 16) / 234, 0, 1)
                        local targetFov = activeBaseFov + (speedPercent * Settings.FovSensitivity)
                        CurrentCamera.FieldOfView = math.max(CurrentCamera.FieldOfView + (targetFov - CurrentCamera.FieldOfView) * math.clamp(8 * deltaTime, 0, 1), 1)
                    else
                        CurrentCamera.FieldOfView = CurrentCamera.FieldOfView + (activeBaseFov - CurrentCamera.FieldOfView) * math.clamp(8 * deltaTime, 0, 1)
                    end
                end

                if Settings.WaterEnabled and moveDir.Magnitude > 0.05 and actualSpeed >= Settings.WaterThreshold then
                    local waterParams = RaycastParams.new()
                    waterParams.FilterType = Enum.RaycastFilterType.Exclude
                    waterParams.FilterDescendantsInstances = {char, CurrentCamera, VfxFolder}
                    waterParams.IgnoreWater = false
                    
                    local ray = workspace:Raycast(rootPart.Position + Vector3.new(0, 2, 0), Vector3.new(0, -9, 0), waterParams)
                    if ray and ray.Material == Enum.Material.Water then
                        WaterPlatform.CFrame = CFrame.new(rootPart.Position.X, ray.Position.Y - 0.5, rootPart.Position.Z)
                        WaterPlatform.CanCollide = true
                    else
                        WaterPlatform.CanCollide = false
                    end
                else
                    WaterPlatform.CanCollide = false
                end

                if moveDir.Magnitude > 0 and actualSpeed >= Settings.SoundBarrier then
                    createSpeedLinesVFX()
                    if not crossedSoundBarrier then
                        crossedSoundBarrier = true playSonicBoomSound() createJetSonicBoomVFX(rootPart.Position, moveDir)
                    end
                elseif actualSpeed < (Settings.SoundBarrier - 15) then crossedSoundBarrier = false end

                if moveDir.Magnitude > 0 and actualSpeed > 35 then
                    if (rootPart.Position - lastGhostPos).Magnitude >= 4.0 then 
                        createGhostAfterimage(char, ATrainBlue) 
                        lastGhostPos = rootPart.Position 
                    end
                    if not wasHighSpeed then wasHighSpeed = true stopPool(RunSoundPool) playSmartSoundAI("Run", 0.0, 3.2, actualSpeed) playShockwaveSound() end
                else
                    if wasHighSpeed and (moveDir.Magnitude == 0 or actualSpeed < 12) then wasHighSpeed = false stopPool(RunSoundPool) end
                end
            end
        end)
    else
        local CurrentCamera = workspace.CurrentCamera
        if CurrentCamera then CurrentCamera.FieldOfView = Settings.FovSystemEnabled and Settings.BaseFov or 70 end
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = 16 end stopPool(RunSoundPool)
        WaterPlatform.CanCollide = false
        actualSpeed = 16
    end
end

local function executeDashEngine()
    local char = LocalPlayer.Character
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local CurrentCamera = workspace.CurrentCamera
    if rootPart and humanoid and humanoid.Health > 0 then
        isDashing = true local moveDirection = humanoid.MoveDirection
        if moveDirection.Magnitude < 0.1 then local look = CurrentCamera and CurrentCamera.CFrame.LookVector or rootPart.CFrame.LookVector moveDirection = Vector3.new(look.X, 0, look.Z) end
        moveDirection = moveDirection.Magnitude < 0.1 and rootPart.CFrame.LookVector or moveDirection.Unit
        playSonicBoomSound() createSonicBoomVFX(rootPart.Position, moveDirection)
        
        local rp = RaycastParams.new() 
        rp.FilterType = Enum.RaycastFilterType.Exclude 
        rp.FilterDescendantsInstances = {char, CurrentCamera, VfxFolder}
        
        if Settings.DashType == "Normal" then
            task.spawn(function()
                local steps, dist = 12, (Settings.DashPower * 0.16) / 12
                for i = 1, steps do
                    if not char or not rootPart or humanoid.Health <= 0 then break end
                    local target = rootPart.Position + (moveDirection * dist)
                    local ray = workspace:Raycast(rootPart.Position, moveDirection * dist, rp)
                    local downRay = workspace:Raycast(target + Vector3.new(0, 3, 0), Vector3.new(0, -7, 0), rp)
                    if downRay and humanoid.FloorMaterial ~= Enum.Material.Air then target = Vector3.new(target.X, downRay.Position.Y + 3, target.Z) end
                    if i % 2 == 0 then createGhostAfterimage(char, ATrainBlue) end
                    if ray and not Settings.NoclipEnabled then char:PivotTo(CFrame.new(ray.Position - (moveDirection * 1.5)) * rootPart.CFrame.Rotation) break
                    else char:PivotTo(CFrame.new(target) * rootPart.CFrame.Rotation) end
                    RunService.Heartbeat:Wait()
                end
                isDashing = false
            end)
        elseif Settings.DashType == "Blink" then
            local target = rootPart.Position + (moveDirection * Settings.BlinkDistance)
            local ray = workspace:Raycast(rootPart.Position, moveDirection * Settings.BlinkDistance, rp)
            if ray and not Settings.NoclipEnabled then char:PivotTo(CFrame.new(ray.Position - (moveDirection * 1.5)) * rootPart.CFrame.Rotation)
            else char:PivotTo(CFrame.new(target) * rootPart.CFrame.Rotation) end isDashing = false
        end
    end
end

