local function stopCustomAnim()
    if currentAnimTrack then
        currentAnimTrack:Stop()
        currentAnimTrack = nil
        lastAnimId = nil
    end
end

local function manageBypassAnimation(humanoid, moveDir)
    if moveDir.Magnitude > 0.05 then
        local animId = "rbxassetid://180426354" 
        local animateScript = humanoid.Parent:FindFirstChild("Animate")
        if animateScript then
            local runObj = animateScript:FindFirstChild("run") or animateScript:FindFirstChild("walk")
            local animNode = runObj and runObj:FindFirstChildOfClass("Animation")
            if animNode and animNode.AnimationId ~= "" then animId = animNode.AnimationId end
        end
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if animator then
            if lastAnimId ~= animId then
                stopCustomAnim()
                local newAnim = Instance.new("Animation")
                newAnim.AnimationId = animId
                local success, track = pcall(function() return animator:LoadAnimation(newAnim) end)
                if success and track then
                    currentAnimTrack = track
                    currentAnimTrack.Looped = true
                    currentAnimTrack:Play(0.1)
                    lastAnimId = animId
                end
            end
            if currentAnimTrack then
                local targetSpeed = math.clamp(actualSpeed / 16, 1.0, 6.0)
                currentAnimTrack:AdjustSpeed(targetSpeed)
            end
        end
    else
        stopCustomAnim()
    end
end

-- UI Yardımcı Elemanları
local function addStroke(parent, color, thickness, transparency)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or BorderColor
    stroke.Thickness = thickness or 1
    stroke.Transparency = transparency or 0
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = parent
    return stroke
end

local function addGradient(parent, colors)
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new(colors)
    gradient.Rotation = 45
    gradient.Parent = parent
    return gradient
end

