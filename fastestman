local function SetupSlider(button, track, min, max, onUpdate, isFloat)
    local dragging, sliderInput = false, nil
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true sliderInput = input
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false sliderInput = nil end end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == sliderInput and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local relativeX = input.Position.X - track.AbsolutePosition.X
            local percentage = math.clamp(relativeX / track.AbsoluteSize.X, 0, 1)
            button.Position = UDim2.new(percentage, -7, 0, -4)
            local rawValue = min + ((max - min) * percentage)
            local finalValue = isFloat and math.floor(rawValue * 10) / 10 or math.floor(rawValue)
            onUpdate(finalValue)
        end
    end)
end

