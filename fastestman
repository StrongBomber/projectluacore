local function cleanEspOfPlayer(player)
    local pName = player.Name
    local b = EspFolder:FindFirstChild(pName .. "_Box") if b then b:Destroy() end
    local t = EspFolder:FindFirstChild(pName .. "_Tracer") if t then t:Destroy() end
    local n = EspFolder:FindFirstChild(pName .. "_Name") if n then n:Destroy() end
    if player.Character then
        local c = player.Character:FindFirstChild("RaiwesyChams") if c then c:Destroy() end
    end
end

local function cleanAllEsp()
    EspFolder:ClearAllChildren()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then
            local c = p.Character:FindFirstChild("RaiwesyChams") if c then c:Destroy() end
        end
    end
end

local function runEspEngine(state)
    Settings.EspMasterEnabled = state
    EspMasterBtn.Text = state and "MASTER ESP: OPERATIONAL" or "MASTER ESP: DISABLED"
    tweenColor(EspMasterBtn, state and NeonGreen or CrimsonRed)
    
    if Connections.EspLoop then Connections.EspLoop:Disconnect() Connections.EspLoop = nil end
    if not state then cleanAllEsp() return end
    
    Connections.EspLoop = RunService.RenderStepped:Connect(function()
        local cam = workspace.CurrentCamera
        if not cam then return end
        
        for _, p in ipairs(Players:GetPlayers()) do
            if p == LocalPlayer then continue end
            
            local char = p.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            
            -- Ölü karakter izolasyonu
            if not (char and root and hum and hum.Health > 0) then
                cleanEspOfPlayer(p)
                continue
            end
            
            -- Takım Kontrolü
            if Settings.EspTeamCheck and p.Team == LocalPlayer.Team then
                cleanEspOfPlayer(p)
                continue
            end
            
            local pos, onScreen = cam:WorldToViewportPoint(root.Position)
            local pName = p.Name
            
            -- 1. BOX ESP
            if Settings.EspBoxes and onScreen then
                local box = EspFolder:FindFirstChild(pName .. "_Box")
                if not box then
                    box = Instance.new("BillboardGui")
                    box.Name = pName .. "_Box"
                    box.Size = UDim2.new(4.5, 0, 6, 0)
                    box.AlwaysOnTop = true
                    
                    local frame = Instance.new("Frame")
                    frame.Size = UDim2.new(1, 0, 1, 0)
                    frame.BackgroundTransparency = 1
                    frame.Parent = box
                    addStroke(frame, ATrainBlue, 1.8, 0)
                    box.Parent = EspFolder
                end
                box.Adornee = root
            else
                local b = EspFolder:FindFirstChild(pName .. "_Box") if b then b:Destroy() end
            end
            
            -- 2. TRACER ESP
            if Settings.EspTracers and onScreen then
                local tracer = EspFolder:FindFirstChild(pName .. "_Tracer")
                if not tracer then
                    tracer = Instance.new("Frame")
                    tracer.Name = pName .. "_Tracer"
                    tracer.BorderSizePixel = 0
                    tracer.BackgroundColor3 = ATrainBlue
                    tracer.AnchorPoint = Vector2.new(0.5, 0.5)
                    tracer.Parent = EspFolder
                end
                local screenCenter = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 1.1)
                local targetPos = Vector2.new(pos.X, pos.Y)
                local distance = (targetPos - screenCenter).Magnitude
                tracer.Size = UDim2.new(0, distance, 0, 2)
                tracer.Position = UDim2.new(0, (screenCenter.X + targetPos.X) / 2, 0, (screenCenter.Y + targetPos.Y) / 2)
                tracer.Rotation = math.deg(math.atan2(targetPos.Y - screenCenter.Y, targetPos.X - screenCenter.X))
            else
                local t = EspFolder:FindFirstChild(pName .. "_Tracer") if t then t:Destroy() end
            end
            
            -- 3. CHAMS ESP
            if Settings.EspChams then
                local cham = char:FindFirstChild("RaiwesyChams")
                if not cham then
                    cham = Instance.new("Highlight")
                    cham.Name = "RaiwesyChams"
                    cham.FillColor = ATrainBlue
                    cham.FillTransparency = 0.45
                    cham.OutlineColor = Color3.fromRGB(255, 255, 255)
                    cham.OutlineTransparency = 0.1
                    cham.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    cham.Parent = char
                end
            else
                local c = char:FindFirstChild("RaiwesyChams") if c then c:Destroy() end
            end
            
            -- 4. NAME & DISTANCE ESP
            if Settings.EspNames and onScreen then
                local nameGui = EspFolder:FindFirstChild(pName .. "_Name")
                if not nameGui then
                    nameGui = Instance.new("BillboardGui")
                    nameGui.Name = pName .. "_Name"
                    nameGui.Size = UDim2.new(0, 150, 0, 30)
                    nameGui.AlwaysOnTop = true
                    nameGui.StudsOffset = Vector3.new(0, 3.8, 0)
                    
                    local lbl = Instance.new("TextLabel")
                    lbl.Size = UDim2.new(1, 0, 1, 0)
                    lbl.BackgroundTransparency = 1
                    lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
                    lbl.Font = Enum.Font.GothamBold
                    lbl.TextSize = 10
                    lbl.Parent = nameGui
                    addStroke(lbl, Color3.fromRGB(0,0,0), 1)
                    nameGui.Parent = EspFolder
                end
                nameGui.Adornee = root
                local dist = math.floor((root.Position - cam.CFrame.Position).Magnitude)
                nameGui.TextLabel.Text = pName .. " [" .. dist .. "m]"
            else
                local n = EspFolder:FindFirstChild(pName .. "_Name") if n then n:Destroy() end
            end
            
        end
    end)
end

