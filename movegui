StatusLabel.BackgroundTransparency = 1
StatusLabel.Text = "Hazır"
StatusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
StatusLabel.TextScaled = true
StatusLabel.Font = Enum.Font.Gotham
StatusLabel.Parent = MainFrame

-- Animasyon fonksiyonu
local function tweenFrame(frame, goal)
    local tween = TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), goal)
    tween:Play()
end

-- GUI Taşıma Fonksiyonu
local function transferGui(guiName)
    local success = false
    
    -- CoreGui'de GUI ara
    local targetGui = CoreGui:FindFirstChild(guiName)
    
    if targetGui and targetGui:IsA("ScreenGui") then
        -- StarterGui'ye kopyala
        local newGui = targetGui:Clone()
        newGui.Parent = StarterGui
        newGui.ResetOnSpawn = false
        
        -- PlayerGui'ye de ekle (hemen görünmesi için)
        local playerCopy = newGui:Clone()
        playerCopy.Parent = playerGui
        
        success = true
        StatusLabel.Text = "'" .. guiName .. "' başarıyla taşındı!"
        StatusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
    else
        StatusLabel.Text = "Hata: '" .. guiName .. "' bulunamadı!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 150, 150)
    end
    
    return success
end

-- Buton olayları
TransferButton.MouseButton1Click:Connect(function()
    local guiName = NameBox.Text
    
    if guiName ~= "" and guiName ~= "GUI Adını Girin" then
        StatusLabel.Text = "Taşıyor..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 150)
        
        wait(0.5)
        transferGui(guiName)
    else
        StatusLabel.Text = "Lütfen GUI adını girin!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 150, 150)
    end
end)

CloseButton.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
end)

-- Hover efektleri
TransferButton.MouseEnter:Connect(function()
    tweenFrame(TransferButton, {BackgroundColor3 = Color3.fromRGB(0, 200, 255)})
end)

TransferButton.MouseLeave:Connect(function()
    tweenFrame(TransferButton, {BackgroundColor3 = Color3.fromRGB(0, 170, 255)})
end)

CloseButton.MouseEnter:Connect(function()
    tweenFrame(CloseButton, {BackgroundColor3 = Color3.fromRGB(255, 120, 120)})
end)

CloseButton.MouseLeave:Connect(function()
    tweenFrame(CloseButton, {BackgroundColor3 = Color3.fromRGB(255, 85, 85)})
end)

-- Enter tuşu ile taşıma
NameBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        TransferButton.MouseButton1Click:Fire()
    end
end)

print("GUI Taşıyıcı hazır! CoreGui'deki GUI'leri StarterGui'ye taşıyabilirsiniz.")
