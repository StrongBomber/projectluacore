		if state==Enum.UserInputState.Begin and input.KeyCode==Enum.KeyCode.P and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then ToggleFreecam() end
		return Enum.ContextActionResult.Pass
	end, false, Enum.ContextActionPriority.Low.Value, Enum.KeyCode.P)
