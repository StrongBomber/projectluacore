script:SetAttribute("FreecamEnabled", false)
script:GetAttributeChangedSignal("FreecamEnabled"):Connect(function()
	local v=script:GetAttribute("FreecamEnabled")
	if typeof(v)~="boolean" then script:SetAttribute("FreecamEnabled",freecamEnabled); return end
	if v~=freecamEnabled then
		if v then StartFreecam() else StopFreecam() end
		freecamEnabled=v
	end
end)

