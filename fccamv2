------------------------------------------------------------------------
-- UP/DOWN UI PAD (Temizlenmiş, sadece E/Q butonları)
------------------------------------------------------------------------
local padGui

local function CreateUpDnPad()
	if padGui then padGui:Destroy(); padGui=nil end

	padGui = Instance.new("ScreenGui")
	padGui.Name="FCUpDnPad"; padGui.ResetOnSpawn=false
	padGui.IgnoreGuiInset=true; padGui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
	padGui.Parent=CoreGui

	local BTN = 54; local GAP = 4
	local PAD_W = BTN + GAP*2
	local PAD_H = BTN*2 + GAP*3 + 20

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0, PAD_W, 0, PAD_H)
	frame.Position = UDim2.new(0, 12, 1, -(PAD_H+12))
	frame.BackgroundColor3 = C.padBg
	frame.BackgroundTransparency = 0.1
	frame.BorderSizePixel = 0
	frame.Parent = padGui
	UICornerR(12, frame); UIStrokeC(C.border, 1, frame)

	local header = Instance.new("TextButton")
	header.Size = UDim2.new(1,0,0,20); header.BackgroundColor3 = C.bgDark
	header.BackgroundTransparency = 0.1; header.BorderSizePixel = 0
	header.Text = "✥ ELEV"; header.Font = Enum.Font.Code
	header.TextSize = 10; header.TextColor3 = C.textDim; header.Parent = frame
	UICornerR(10, header)
	local hFix = Instance.new("Frame"); hFix.Size=UDim2.new(1,0,0,6); hFix.Position=UDim2.new(0,0,1,-6)
	hFix.BackgroundColor3=C.bgDark; hFix.BorderSizePixel=0; hFix.Parent=header

	local dragging, dragStart, frameStart = false, nil, nil
	header.InputBegan:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
			dragging=true; dragStart=Vector2.new(inp.Position.X, inp.Position.Y); frameStart=frame.Position
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if not dragging then return end
		if inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch then
			local d = Vector2.new(inp.Position.X, inp.Position.Y) - dragStart
			frame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + d.X, frameStart.Y.Scale, frameStart.Y.Offset + d.Y)
		end
	end)
	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then dragging = false end
	end)

	local function MakeKey(label, col, row, padKey)
		local btn = Instance.new("TextButton")
		btn.Size = UDim2.new(0, BTN, 0, BTN)
		btn.Position = UDim2.new(0, GAP + col*(BTN+GAP), 0, 20 + GAP + row*(BTN+GAP))
		btn.BackgroundColor3 = C.padBtn; btn.BackgroundTransparency = 0.15; btn.BorderSizePixel = 0
		btn.Text = label; btn.Font = Enum.Font.Code; btn.TextSize = 20
		btn.TextColor3 = C.text; btn.AutoButtonColor = false; btn.Parent = frame
		UICornerR(8, btn); UIStrokeC(Color3.fromRGB(60, 82, 120), 1, btn)

		local function Press() Pad[padKey] = 1; btn.BackgroundColor3 = C.padBtnAct end
		local function Release() Pad[padKey] = 0; btn.BackgroundColor3 = C.padBtn end
		btn.MouseButton1Down:Connect(Press); btn.MouseButton1Up:Connect(Release); btn.MouseLeave:Connect(Release)
		btn.InputBegan:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.Touch then Press() end end)
		btn.InputEnded:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.Touch then Release() end end)
	end

	MakeKey("E↑", 0, 0, "Up")
	MakeKey("Q↓", 0, 1, "Down")

	return padGui
end

local function DestroyUpDnPad()
	if padGui then padGui:Destroy(); padGui=nil end
	for k in pairs(Pad) do Pad[k] = 0 end
end

------------------------------------------------------------------------
-- DestroyScript
------------------------------------------------------------------------
local function DestroyScript()
	if freecamEnabled then StopFreecam(); freecamEnabled = false end
	confOpen = false; if confGui then confGui:Destroy(); confGui = nil end
	if hudGui then hudGui:Destroy(); hudGui = nil end
	DestroyUpDnPad()
	pcall(function() ContextActionService:UnbindAction("FCToggle") end)
	for _, c in ipairs(charLockConns) do c:Disconnect() end
	charLockConns = {}
	pcall(function() script:SetAttribute("FreecamEnabled", nil) end)
	pcall(function() script:Destroy() end)
end

