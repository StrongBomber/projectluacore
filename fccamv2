------------------------------------------------------------------------
-- Karakter kilidi (WalkSpeed = 0 yerine PlatformStand + Anchored)
------------------------------------------------------------------------
local charLockConns = {}

local function ApplyCharLock(locked)
	for _, c in ipairs(charLockConns) do c:Disconnect() end
	charLockConns = {}

	local char = LocalPlayer.Character
	if not char then return end

	local hrp = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")

	if locked then
		if hrp then hrp.Anchored = true end
		if hum then hum.PlatformStand = true end -- MoveVector'un kesilmesini engeller
		
		charLockConns[#charLockConns+1] = LocalPlayer.CharacterAdded:Connect(function(newChar)
			task.wait(0.1)
			local newHrp = newChar:FindFirstChild("HumanoidRootPart")
			local newHum = newChar:FindFirstChildOfClass("Humanoid")
			if newHrp then newHrp.Anchored = true end
			if newHum then newHum.PlatformStand = true end
		end)
	else
		if hrp then hrp.Anchored = false end
		if hum then hum.PlatformStand = false end
	end
end

------------------------------------------------------------------------
-- Spring
------------------------------------------------------------------------
local Spring = {} do
	Spring.__index = Spring
	function Spring.new(freq, pos)
		local s = setmetatable({}, Spring)
		s.f = freq; s.p = pos; s.v = pos*0
		return s
	end
	function Spring:Update(dt, goal)
		local f      = self.f * 2*pi
		local p0, v0 = self.p, self.v
		local offset = goal - p0
		local decay  = exp(-f*dt)
		self.p = goal + (v0*dt - offset*(f*dt+1))*decay
		self.v = (f*dt*(offset*f - v0) + v0)*decay
		return self.p
	end
	function Spring:SetFreq(f) self.f = f end
	function Spring:Reset(pos) self.p = pos; self.v = pos*0 end
end

------------------------------------------------------------------------
-- Kamera state
------------------------------------------------------------------------
local cameraPos = Vector3.new()
local cameraRot = Vector3.new()
local cameraFov = 70

local velSpring  = Spring.new(Config.MoveSmooth, Vector3.new())
local panSpring  = Spring.new(Config.LookSmooth, Vector2.new())
local fovSpring  = Spring.new(Config.FovSmooth,  0)
local rollSpring = Spring.new(Config.RollSmooth, 0)

local BASE_NAV_GAIN  = 64
local BASE_FOV_GAIN  = 300
local BASE_ROLL_GAIN = -pi/2
local BASE_PAN_GAIN  = Vector2.new(0.75, 1) * 8
local PITCH_LIMIT    = rad(90)

------------------------------------------------------------------------
-- Up/Down UI pad durumu
------------------------------------------------------------------------
local Pad = {
	Up = 0, Down = 0,
	FovUp = 0, FovDown = 0,
	RollL = 0, RollR = 0,
}

------------------------------------------------------------------------
-- Look drag (sağ taraf)
------------------------------------------------------------------------
local Look = { active=false, last=Vector2.new(), touchId=nil, delta=Vector2.new() }
local touchConns = {}

local function StartTouchCapture()
	touchConns[#touchConns+1] = UserInputService.TouchStarted:Connect(function(input, processed)
		if processed or confOpen then return end
		if not Look.active then
			Look.active  = true
			Look.last    = Vector2.new(input.Position.X, input.Position.Y)
			Look.touchId = input
			Look.delta   = Vector2.new()
		end
	end)
	touchConns[#touchConns+1] = UserInputService.TouchMoved:Connect(function(input, processed)
		if processed or confOpen then Look.delta = Vector2.new(); return end
		if input == Look.touchId then
			local pos = Vector2.new(input.Position.X, input.Position.Y)
			Look.delta = pos - Look.last
			Look.last  = pos
		end
	end)
	touchConns[#touchConns+1] = UserInputService.TouchEnded:Connect(function(input, processed)
		if input == Look.touchId then
			Look.active = false; Look.touchId = nil; Look.delta = Vector2.new()
		end
	end)
end

local function StopTouchCapture()
	for _, c in ipairs(touchConns) do c:Disconnect() end
	touchConns = {}
	Look.active = false; Look.touchId = nil; Look.delta = Vector2.new()
end

------------------------------------------------------------------------
-- Input modülü
------------------------------------------------------------------------
local Input = {} do
	local keyboard = { E=0,Q=0,Z=0,C=0 }
	local mouse    = { Delta=Vector2.new(), MouseWheel=0 }

	function Input.Vel(dt)
		velSpring:SetFreq(Config.MoveSmooth)
		
		-- Yerel ControlModule'dan hareket vektörünü alıyoruz (WASD / Mobil Joystick)
		local moveVec = Controls:GetMoveVector()
		
		-- Yukarı / Aşağı hareketler (Klavye E/Q ve Mobil UI)
		local upDown = (keyboard.E - keyboard.Q) + ((Pad.Up - Pad.Down) * Config.UpDownSpeed)
		
		-- X: Sağ/Sol, Y: Yukarı/Aşağı, Z: İleri/Geri (Roblox'ta ileri negatif Z'dir, GetMoveVector bunu otomatik sağlar)
		local base = Vector3.new(moveVec.X, upDown, moveVec.Z)
		
		return base * Config.MoveSpeed
	end

	function Input.Pan(dt)
		panSpring:SetFreq(Config.LookSmooth)
		local kMouse = Vector2.new()
		if dt > 0 and not confOpen then
			kMouse = (mouse.Delta/dt) * (pi/64/60)
		end
		mouse.Delta = Vector2.new()
		
		local kTouch = Vector2.new()
		if Look.active and dt > 0 and not confOpen then
			local d = Look.delta
			kTouch = Vector2.new(-d.Y, -d.X) * (0.003 * Config.LookSens) / dt
		end
		Look.delta = Vector2.new()
		
		local pan = kMouse + kTouch
		if Config.InvertX then pan = Vector2.new(pan.X, -pan.Y) end
		if Config.InvertY then pan = Vector2.new(-pan.X, pan.Y) end
		return pan
	end

	function Input.Fov(dt)
		fovSpring:SetFreq(Config.FovSmooth)
		local kMouse = dt > 0 and ((mouse.MouseWheel/dt)*(1/60)) or 0
		mouse.MouseWheel = 0
		return kMouse + ((Pad.FovUp - Pad.FovDown) * 0.5 * Config.FovSpeed)
	end

	function Input.Roll(dt)
		rollSpring:SetFreq(Config.RollSmooth)
		return (keyboard.C - keyboard.Z + Pad.RollR - Pad.RollL) * 1.0
	end

	local function Keypress(action, state, input)
		local n = input.KeyCode.Name
		if keyboard[n] ~= nil then
			keyboard[n] = state == Enum.UserInputState.Begin and 1 or 0
		end
		return Enum.ContextActionResult.Sink
	end

	local function MousePanFn(action, state, input)
		if confOpen then return Enum.ContextActionResult.Sink end
		mouse.Delta = Vector2.new(-input.Delta.y, -input.Delta.x)
		return Enum.ContextActionResult.Sink
	end

	local function MouseWheelFn(action, state, input)
		mouse.MouseWheel = -input.Position.z
		return Enum.ContextActionResult.Sink
	end

	function Input.StartCapture()
		-- Sadece özel tuşları (E, Q, Z, C) bind ediyoruz. WASD native sisteme bırakıldı.
		ContextActionService:BindActionAtPriority("FCKeyboard", Keypress, false,
			Enum.ContextActionPriority.High.Value,
			Enum.KeyCode.E, Enum.KeyCode.Q, Enum.KeyCode.Z, Enum.KeyCode.C)
		ContextActionService:BindActionAtPriority("FCMousePan",   MousePanFn,   false, Enum.ContextActionPriority.High.Value, Enum.UserInputType.MouseMovement)
		ContextActionService:BindActionAtPriority("FCMouseWheel", MouseWheelFn, false, Enum.ContextActionPriority.High.Value, Enum.UserInputType.MouseWheel)
		if IsMobile then StartTouchCapture() end
	end

	function Input.StopCapture()
		for k in pairs(keyboard) do keyboard[k] = 0 end
		mouse.Delta = Vector2.new(); mouse.MouseWheel = 0
		ContextActionService:UnbindAction("FCKeyboard")
		ContextActionService:UnbindAction("FCMousePan")
		ContextActionService:UnbindAction("FCMouseWheel")
		if IsMobile then StopTouchCapture() end
	end
end

------------------------------------------------------------------------
-- StepFreecam
------------------------------------------------------------------------
local function StepFreecam(dt)
	local vel  = velSpring:Update(dt, Input.Vel(dt))
	local pan  = panSpring:Update(dt, Input.Pan(dt))
	local fov  = fovSpring:Update(dt, Input.Fov(dt))
	local roll = rollSpring:Update(dt, Input.Roll(dt))

	local zf = sqrt(tan(rad(70/2)) / tan(rad(cameraFov/2)))
	cameraFov = clamp(cameraFov + fov * BASE_FOV_GAIN * (dt/zf), 1, 120)

	local pv = pan * BASE_PAN_GAIN * (dt/zf)
	cameraRot = Vector3.new(
		clamp(cameraRot.x + pv.X, -PITCH_LIMIT, PITCH_LIMIT),
		(cameraRot.y + pv.Y) % (2*pi),
		cameraRot.z + roll * BASE_ROLL_GAIN * (dt/zf)
	)

	local navGain = Vector3.new(1,1,1) * BASE_NAV_GAIN * Config.MoveSpeed
	local cf = CFrame.new(cameraPos)
		* CFrame.fromOrientation(cameraRot.x, cameraRot.y, cameraRot.z)
		* CFrame.new(vel * navGain * dt)

	cameraPos          = cf.p
	Camera.CFrame      = cf
	Camera.Focus       = cf
	Camera.FieldOfView = cameraFov
end

------------------------------------------------------------------------
-- PlayerState
------------------------------------------------------------------------
local PlayerState = {} do
	local saved = {}
	local setCores = { BadgesNotificationsActive=true, PointsNotificationsActive=true }
	function PlayerState.Push()
		for k in pairs(setCores) do
			saved[k] = StarterGui:GetCore(k); StarterGui:SetCore(k, false)
		end
		saved.fov=Camera.FieldOfView; Camera.FieldOfView=70
		saved.ct=Camera.CameraType;   Camera.CameraType=Enum.CameraType.Custom
		saved.cf=Camera.CFrame;       saved.foc=Camera.Focus
		saved.mb=UserInputService.MouseBehavior
		UserInputService.MouseBehavior=Enum.MouseBehavior.Default
	end
	function PlayerState.Pop()
		for k,v in pairs(setCores) do StarterGui:SetCore(k, saved[k] or v) end
		Camera.FieldOfView=saved.fov; Camera.CameraType=saved.ct
		Camera.CFrame=saved.cf;       Camera.Focus=saved.foc
		UserInputService.MouseBehavior=saved.mb
	end
end

------------------------------------------------------------------------
-- Start / Stop / Toggle
------------------------------------------------------------------------
local freecamEnabled = false

local function StartFreecam()
	local cf = Camera.CFrame
	cameraRot = Vector3.new(cf:toEulerAnglesYXZ())
	cameraPos = cf.p
	cameraFov = Camera.FieldOfView
	velSpring:Reset(Vector3.new()); panSpring:Reset(Vector2.new())
	fovSpring:Reset(0);            rollSpring:Reset(0)
	PlayerState.Push()
	if Config.CharLock then ApplyCharLock(true) end
	RunService:BindToRenderStep("Freecam", Enum.RenderPriority.Camera.Value, StepFreecam)
	Input.StartCapture()
end

local function StopFreecam()
	Input.StopCapture()
	RunService:UnbindFromRenderStep("Freecam")
	ApplyCharLock(false)
	PlayerState.Pop()
end

local function ToggleFreecam()
	freecamEnabled = not freecamEnabled
	if freecamEnabled then StartFreecam() else StopFreecam() end
	script:SetAttribute("FreecamEnabled", freecamEnabled)
end

