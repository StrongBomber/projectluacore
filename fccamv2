local function MakeSlider(parent, configKey, minVal, maxVal, yPos, labelText, fmt)
	fmt = fmt or "%.2f"
	local row = Instance.new("Frame"); row.Size=UDim2.new(1,0,0,30); row.Position=UDim2.new(0,0,0,yPos)
	row.BackgroundTransparency=1; row.Parent=parent
	local lbl=Lbl(labelText,11,C.textDim,row); lbl.Size=UDim2.new(0,138,1,0)
	local valLbl=Lbl(string.format(fmt,Config[configKey]),11,C.text,row,Enum.TextXAlignment.Right)
	valLbl.Size=UDim2.new(0,46,1,0); valLbl.Position=UDim2.new(1,-46,0,0)
	local track=Instance.new("Frame"); track.Size=UDim2.new(1,-192,0,6); track.Position=UDim2.new(0,142,0.5,-3)
	track.BackgroundColor3=C.sliderBg; track.BorderSizePixel=0; track.Parent=row; UICornerR(3,track)
	local fill=Instance.new("Frame"); fill.BackgroundColor3=C.sliderFill; fill.BorderSizePixel=0
	fill.Size=UDim2.new(0,0,1,0); fill.Parent=track; UICornerR(3,fill)
	local knob=Instance.new("Frame"); knob.Size=UDim2.new(0,14,0,14); knob.AnchorPoint=Vector2.new(0.5,0.5)
	knob.BackgroundColor3=Color3.fromRGB(240,245,255); knob.BorderSizePixel=0; knob.Parent=track; UICornerR(7,knob)

	local function SetVal(t)
		t = clamp(t,0,1)
		Config[configKey] = math.floor((minVal + t*(maxVal-minVal))*100+0.5)/100
		fill.Size = UDim2.new(t,0,1,0); knob.Position = UDim2.new(t,0,0.5,0)
		valLbl.Text = string.format(fmt, Config[configKey])
	end
	SetVal((Config[configKey]-minVal)/(maxVal-minVal))

	local dragging = false
	local function ApplyX(absX)
		local as=track.AbsoluteSize; if as.X==0 then return end
		SetVal((absX-track.AbsolutePosition.X)/as.X)
	end
	track.InputBegan:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
			dragging=true; ApplyX(inp.Position.X)
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if not dragging then return end
		if inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch then ApplyX(inp.Position.X) end
	end)
	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then dragging=false end
	end)
end

